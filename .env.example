# Copy to .env and fill in. PUBLIC_* vars are exposed to the browser (safe).
# Leave blank to disable a feature cleanly (no errors).

# Analytics (browser)
PUBLIC_GA4_ID=
PUBLIC_META_PIXEL_ID=

# Contact routing (browser). Defaults baked into src/lib/site.ts if blank.
PUBLIC_PHONE=+19399699999
PUBLIC_PHONE_ALT=+17873470799
PUBLIC_WHATSAPP=19399699999

# Server-only: GoHighLevel inbound webhook URL for the lead function.
# Get it in GHL: Automation > Workflows > Trigger "Inbound Webhook".
GHL_WEBHOOK_URL=
