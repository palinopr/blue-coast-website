---
import '@fontsource-variable/manrope/index.css';
import '@fontsource-variable/sora/index.css';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ActionBar from '../components/ActionBar.astro';
import { site } from '../lib/site';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
}
const { title, description, ogImage = '/assets/video/blue-coast-film-final-poster.jpg' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="es-PR" class="no-js">
  <head>
    <script is:inline>document.documentElement.classList.remove('no-js');</script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#050a16" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
    <meta property="og:locale" content="es_PR" />
    <meta name="twitter:card" content="summary_large_image" />

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'LocalBusiness',
        name: site.name,
        description:
          'Limpieza de tanques diésel, pulido de combustible y mantenimiento preventivo de generadores en Puerto Rico.',
        telephone: site.phone,
        email: site.email,
        url: `https://${site.domain}`,
        areaServed: 'Puerto Rico',
        address: { '@type': 'PostalAddress', addressRegion: 'PR', addressCountry: 'PR' },
      })}
    />
  </head>
  <body>
    <a href="#main" class="skip">Saltar al contenido</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <ActionBar />

    <!-- analítica (inerte sin IDs) -->
    <script is:inline define:vars={{ ga4: site.ga4, pixel: site.pixel }}>
      window.dataLayer = window.dataLayer || [];
      window.gtag = function () { window.dataLayer.push(arguments); };
      if (ga4) {
        var s = document.createElement('script');
        s.async = true; s.src = 'https://www.googletagmanager.com/gtag/js?id=' + ga4;
        document.head.appendChild(s);
        gtag('js', new Date()); gtag('config', ga4);
      }
      if (pixel) {
        !(function (f, b, e, v, n, t, s) {
          if (f.fbq) return; n = f.fbq = function () { n.callMethod ? n.callMethod.apply(n, arguments) : n.queue.push(arguments); };
          if (!f._fbq) f._fbq = n; n.push = n; n.loaded = !0; n.version = '2.0'; n.queue = [];
          t = b.createElement(e); t.async = !0; t.src = v; s = b.getElementsByTagName(e)[0]; s.parentNode.insertBefore(t, s);
        })(window, document, 'script', 'https://connect.facebook.net/en_US/fbevents.js');
        fbq('init', pixel); fbq('track', 'PageView');
      }
      window.bcTrack = function (event, params) {
        params = params || {};
        if (window.gtag && ga4) gtag('event', event, Object.assign({ transport_type: 'beacon' }, params));
        if (window.fbq && pixel) {
          var fb = { whatsapp_click: 'Contact', call_click: 'Contact', lead_submit: 'Lead' }[event] || 'Lead';
          fbq('track', fb, params);
        }
      };
    </script>

    <script>
      // Revelado premium al entrar en pantalla
      const io = new IntersectionObserver(
        (es) => es.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } }),
        { threshold: 0.12, rootMargin: '0px 0px -30px 0px' }
      );
      document.querySelectorAll('.rv').forEach((el) => io.observe(el));

      // Clics de contacto con atribución
      const track = (ev: string) => (e: Event) => {
        const el = e.currentTarget as HTMLElement;
        (window as any).bcTrack?.(ev, { source: el.dataset.src || '' });
      };
      document.querySelectorAll('[data-track="call"]').forEach((a) => a.addEventListener('click', track('call_click')));
      document.querySelectorAll('[data-track="whatsapp"]').forEach((a) => a.addEventListener('click', track('whatsapp_click')));
    </script>
  </body>
</html>
