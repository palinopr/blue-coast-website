---
import Base from '../layouts/Base.astro';
import { site, waLink, waMsg, phoneDisplay } from '../lib/site';
// El evento de conversión del embudo se dispara aquí (una sola vez), cuando
// el DOM terminó de cargar y bcTrack ya existe.
---
<Base
  title="Gracias | BCD Diesel"
  description="Recibimos su solicitud. Le contactaremos en minutos."
>
  <section class="gracias" data-hero>
    <div class="sheet gracias__in">
      <div class="gracias__mark" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
      </div>
      <h1 class="h-display">Recibido. <span class="grad-text">Le contactamos en minutos.</span></h1>
      <p class="lede">
        Un técnico de BCD Diesel revisará su solicitud y se comunicará con usted en breve.
        Si es urgente, use la vía rápida:
      </p>
      <div class="gracias__cta">
        <a href={`tel:${site.phone}`} class="btn btn-ambar" data-track="call" data-src="gracias">Llamar · {phoneDisplay(site.phone)}</a>
        <a href={waLink(waMsg.gracias)} target="_blank" rel="noopener" class="btn btn-wa" data-track="whatsapp" data-src="gracias">WhatsApp</a>
      </div>
      <a href="/" class="gracias__back small">← Volver al inicio</a>
    </div>
  </section>

  <script is:inline>
    window.addEventListener('DOMContentLoaded', function () {
      if (window.bcTrack) window.bcTrack('lead_submit', { stage: 'thankyou' });
    });
  </script>
</Base>

<style>
  .gracias { min-height: 62svh; display: grid; place-items: center; padding-block: clamp(56px, 8vw, 100px); }
  .gracias__in { max-width: 640px; display: flex; flex-direction: column; align-items: flex-start; gap: 20px; }
  .gracias__mark {
    width: 64px; height: 64px;
    border-radius: 50%;
    display: grid; place-items: center;
    color: var(--wa);
    border: 1.5px solid rgba(37, 211, 102, 0.5);
    background: rgba(37, 211, 102, 0.1);
    box-shadow: 0 0 40px -8px rgba(37, 211, 102, 0.5);
  }
  .gracias__mark svg { width: 30px; height: 30px; }
  .gracias__cta { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 6px; }
  .gracias__back { color: var(--ink-70); text-decoration: none; font-weight: 700; margin-top: 10px; }
  .gracias__back:hover { color: var(--ambar); }
</style>
