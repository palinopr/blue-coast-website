---
import Base from '../layouts/Base.astro';
import MuestraBanner from '../components/MuestraBanner.astro';
import { site, waLink, waMsg, phoneDisplay, obras } from '../lib/site';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

import fotoDamas from '../assets/img/field/hospital-damas-ponce-2.jpg';

const fieldImgs = import.meta.glob<{ default: ImageMetadata }>('/src/assets/img/field/*.jpg', { eager: true });
const byName = Object.fromEntries(Object.entries(fieldImgs).map(([p, m]) => [p.split('/').pop()!, m.default]));
const galeria = obras.filter((o) => o.foto && byName[o.foto] && o.foto !== 'hospital-damas-ponce-2.jpg');
---
<Base
  title="Trabajos realizados | BCD Diesel Puerto Rico"
  description="Trabajos reales de limpieza y pulido de combustible diésel en hospitales, industria, comercios y condominios de Puerto Rico — con tipo de proyecto, municipio y capacidad del tanque."
>
  <section class="cover" data-hero>
    <div class="sheet">
      <span class="kicker rv">Trabajos reales</span>
      <h1 class="h-display rv" style="--d:.05s">Obra entregada, <span class="grad-text">con capacidad y evidencia.</span></h1>
      <p class="lede rv" style="--d:.1s">
        Fotos de nuestros técnicos en el sitio de trabajo — no banco de imágenes.
        La evidencia es el argumento.
      </p>
    </div>
  </section>

  <section class="sec sec--tightop">
    <div class="sheet">
      <div class="feat edge rv">
        <div class="feat__media">
          <Image src={fotoDamas} alt="Tanque de 93,000 galones en proyecto hospitalario en Ponce" widths={[420, 720]} sizes="(max-width: 860px) 92vw, 40vw" format="webp" loading="eager" />
        </div>
        <div class="feat__copy">
          <span class="kicker">Proyecto destacado</span>
          <p class="feat__num h-display grad-text">93,000 <small>gal</small></p>
          <h2 class="h-display">Proyecto hospitalario · Ponce</h2>
          <p class="muted">
            Pulido de combustible a gran escala para el sistema de respaldo del hospital.
            El proyecto de mayor capacidad en nuestro registro.
          </p>
        </div>
      </div>

      <div class="gal">
        {galeria.map((o, i) => (
          <figure class="gal__item rv" style={`--d:${0.04 * i}s`}>
            <Image src={byName[o.foto!]} alt={`${o.cliente} — ${o.alcance.toLowerCase()}`} widths={[420, 640]} sizes="(max-width: 720px) 92vw, 32vw" format="webp" loading="lazy" />
            <figcaption><b>{o.cliente}</b><span class="small">{o.municipio} · {o.tanque}</span></figcaption>
          </figure>
        ))}
      </div>

      <div class="registro rv">
        <h2 class="h-display registro__t">Registro de servicio</h2>
        <ul class="registro__list">
          {obras.map((o) => (
            <li>
              <b>{o.cliente}</b>
              <span class="muted small">{o.municipio}</span>
              <span class="registro__gal">{o.tanque}</span>
              <span class="muted small registro__alc">{o.alcance}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <MuestraBanner />
</Base>

<style>
  .cover { padding-block: clamp(56px, 8vw, 110px) clamp(20px, 3vw, 40px); }
  .cover h1 { margin-top: 18px; max-width: 20ch; }
  .cover .lede { margin-top: 16px; max-width: 54ch; }
  .sec--tightop { padding-top: clamp(24px, 4vw, 56px); }

  .feat { display: grid; grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr); overflow: clip; }
  .feat__media { min-height: 320px; position: relative; overflow: clip; }
  .feat__media img { width: 100%; height: 100%; object-fit: cover; filter: saturate(1.08) contrast(1.05); transform: scale(1.02); }
  @media (min-width: 861px) {
    .feat__media::after { content: ''; position: absolute; inset: 0; background: linear-gradient(90deg, transparent 72%, var(--bg-2) 99%); pointer-events: none; }
  }
  @media (max-width: 860px) {
    .feat { grid-template-columns: 1fr; }
    .feat__media { min-height: 240px; }
    .feat__media::after { content: ''; position: absolute; inset: 0; background: linear-gradient(180deg, transparent 72%, var(--bg-2) 99%); pointer-events: none; }
  }
  .feat__copy { padding: clamp(26px, 4vw, 48px); display: flex; flex-direction: column; align-items: flex-start; gap: 14px; }
  .feat__num { font-size: clamp(2.6rem, 2rem + 3vw, 4.4rem); font-weight: 700; letter-spacing: -0.03em; line-height: 1; }
  .feat__num small { font-size: 0.4em; font-weight: 800; }
  .feat__copy p.muted { max-width: 50ch; }

  .gal { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 18px; }
  .gal__item { position: relative; margin: 0; border-radius: var(--r-md); overflow: clip; aspect-ratio: 4 / 5; background: var(--bg); }
  .gal__item img { width: 100%; height: 100%; object-fit: cover; filter: saturate(1.08) contrast(1.05); transform: scale(1.02); transition: transform 0.5s var(--ease); }
  .gal__item:hover img { transform: scale(1.06); }
  .gal__item figcaption { position: absolute; inset: auto 0 0 0; padding: 34px 14px 12px; background: linear-gradient(transparent, rgba(3, 6, 14, 0.92)); }
  .gal__item figcaption b { display: block; font-size: 0.95rem; }
  .gal__item figcaption span { color: var(--ink-70); }
  @media (max-width: 860px) { .gal { grid-template-columns: repeat(2, 1fr); } }

  .registro { margin-top: clamp(44px, 6vw, 72px); }
  .registro__t { font-size: clamp(1.5rem, 1.2rem + 1.4vw, 2.2rem); margin-bottom: 18px; }
  .registro__list { list-style: none; margin: 0; padding: 0; }
  .registro__list li {
    display: grid;
    grid-template-columns: minmax(160px, 1.2fr) 0.7fr 0.6fr 1.2fr;
    gap: 10px 22px;
    align-items: baseline;
    padding-block: 14px;
    border-top: 1px solid var(--line);
  }
  .registro__list li:last-child { border-bottom: 1px solid var(--line); }
  .registro__list b { font-family: var(--f-display); font-weight: 600; font-size: 1rem; }
  .registro__gal { color: var(--ambar); font-weight: 800; }
  @media (max-width: 640px) {
    .registro__list li { grid-template-columns: 1fr auto; }
    .registro__alc { display: none; }
  }
</style>
