---
import Base from '../layouts/Base.astro';
import LeadForm from '../components/LeadForm.astro';
import PRMap from '../components/PRMap.astro';
import { site, waLink, waMsg, phoneDisplay } from '../lib/site';
---
<Base
  title="Contacto | Blue Coast Developers — Pida su muestra gratis"
  description="Pida su muestra de diésel gratis por WhatsApp, teléfono o formulario. Servicio en los 78 municipios de Puerto Rico. Respondemos en minutos, 24/7."
>
  <section class="cover" data-hero>
    <div class="sheet">
      <span class="kicker rv">Contacto</span>
      <h1 class="h-display rv" style="--d:.05s">Hablemos de <span class="grad-text">su tanque.</span></h1>
      <p class="lede rv" style="--d:.1s">
        Dos vías rápidas y un formulario. Respondemos en minutos, no en días.
      </p>
    </div>
  </section>

  <section class="sec sec--tightop" id="contacto">
    <div class="sheet cta">
      <div class="cta__copy">
        <div class="cta__canales rv">
          <a href={`tel:${site.phone}`} class="cta__canal" data-track="call" data-src="contacto">
            <span class="small muted">¿Emergencia? Llame ahora · 24/7</span>
            <b>{phoneDisplay(site.phone)} <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14m-6-6 6 6-6 6"/></svg></b>
          </a>
          <a href={`tel:${site.phoneAlt}`} class="cta__canal" data-track="call" data-src="contacto">
            <span class="small muted">Teléfono alterno</span>
            <b>{phoneDisplay(site.phoneAlt)} <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14m-6-6 6 6-6 6"/></svg></b>
          </a>
          <a href={waLink(waMsg.muestra)} target="_blank" rel="noopener" class="cta__canal" data-track="whatsapp" data-src="contacto">
            <span class="small muted">¿Muestra gratis o mantenimiento? Escríbanos</span>
            <b>WhatsApp directo <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14m-6-6 6 6-6 6"/></svg></b>
          </a>
          <a href={`mailto:${site.email}`} class="cta__canal">
            <span class="small muted">Cotizaciones formales y documentación</span>
            <b>{site.email} <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14m-6-6 6 6-6 6"/></svg></b>
          </a>
        </div>
      </div>
      <div class="cta__form glass rv" style="--d:.1s">
        <h2 class="h-display cta__form-t">Pida su muestra gratis</h2>
        <p class="small muted cta__form-sub">Coordinamos la visita, tomamos la muestra y usted ve el estado de su combustible. Sin compromiso.</p>
        <LeadForm id="lead-contacto" />
      </div>
    </div>
  </section>

  <section class="sec sec--band">
    <div class="sheet">
      <div class="sec-head">
        <span class="kicker rv">Cobertura</span>
        <h2 class="h-display rv" style="--d:.05s">Los 78 municipios. <span class="grad-text">Verifique el suyo.</span></h2>
      </div>
      <div class="rv" style="--d:.1s; margin-top: clamp(24px, 4vw, 40px);">
        <PRMap />
      </div>
    </div>
  </section>
</Base>

<style>
  .cover { padding-block: clamp(56px, 8vw, 110px) clamp(20px, 3vw, 40px); }
  .cover h1 { margin-top: 18px; }
  .cover .lede { margin-top: 16px; max-width: 48ch; }
  .sec--tightop { padding-top: clamp(24px, 4vw, 56px); }

  .cta { display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); gap: clamp(32px, 5vw, 80px); align-items: start; }
  .cta__canales { display: block; }
  .cta__canal {
    display: flex; flex-direction: column; gap: 4px;
    padding: 20px 4px;
    text-decoration: none;
    color: var(--ink);
    border-top: 1px solid var(--line);
    transition: padding-left 0.25s var(--ease);
  }
  .cta__canal:last-child { border-bottom: 1px solid var(--line); }
  .cta__canal:hover { padding-left: 12px; }
  .cta__canal b { display: inline-flex; align-items: center; gap: 12px; font-family: var(--f-display); font-size: clamp(1.25rem, 2.2vw, 1.7rem); letter-spacing: -0.01em; overflow-wrap: anywhere; }
  .cta__canal b svg { width: 20px; height: 20px; color: var(--ambar); flex: none; transition: transform 0.25s var(--ease); }
  .cta__canal:hover b svg { transform: translateX(6px); }
  .cta__canal:hover b { color: var(--ambar); }
  .cta__form { padding: clamp(24px, 3.5vw, 40px); }
  .cta__form-t { margin-bottom: 6px; font-size: clamp(1.4rem, 1.1rem + 1.2vw, 2rem); }
  .cta__form-sub { margin: 0 0 20px; }
  @media (max-width: 900px) { .cta { grid-template-columns: 1fr; } }

  .sec--band {
    background:
      radial-gradient(1000px 500px at 80% -10%, rgba(47, 107, 255, 0.12), transparent 60%),
      linear-gradient(180deg, var(--bg-2), var(--bg));
    border-block: 1px solid var(--line);
  }
</style>
