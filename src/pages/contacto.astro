---
import Base from '../layouts/Base.astro';
import PRMap from '../components/PRMap.astro';
import { site, waLink, waMsg, phoneDisplay } from '../lib/site';
---
<Base
  title="Contacto | BCD Diesel — Pida su muestra gratis"
  description="Pida su muestra de diésel gratis directamente por WhatsApp. Servicio en los 78 municipios de Puerto Rico. Respondemos en minutos, 24/7."
>
  <section class="cover" data-hero>
    <div class="sheet">
      <span class="kicker rv">Contacto</span>
      <h1 class="h-display rv" style="--d:.05s">Hablemos de <span class="grad-text">su tanque.</span></h1>
      <p class="lede rv" style="--d:.1s">
        Una conversación directa por WhatsApp. Sin formularios y sin esperar días.
      </p>
    </div>
  </section>

  <section class="sec sec--tightop" id="contacto">
    <div class="sheet cta">
      <div class="cta__whatsapp glass rv">
        <span class="cta__wa-label"><i aria-hidden="true"></i> WhatsApp directo</span>
        <h2 class="h-display">Pida su muestra gratis. Sin formularios.</h2>
        <p class="muted">Abra el chat y envíe el mensaje listo. Le preguntaremos municipio, tipo de facilidad y capacidad aproximada del tanque.</p>
        <a href={waLink(waMsg.muestra)} target="_blank" rel="noopener" class="btn btn-wa cta__wa-btn" data-track="whatsapp" data-src="contacto-primary">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.945C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 0 1 8.413 3.488 11.82 11.82 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zM6.6 20.2c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.82 9.82 0 0 0 1.523 5.26l-.999 3.648 3.465-.81z"/></svg>
          Abrir WhatsApp y pedir mi muestra
        </a>
        <span class="small cta__response">Respondemos en minutos · 78 municipios</span>
      </div>
      <div class="cta__secondary rv" style="--d:.1s">
        <span class="kicker">Emergencias 24/7</span>
        <h2 class="h-display">Si el generador no puede esperar, llame ahora.</h2>
        <p class="muted">Para servicio urgente, averías o asistencia inmediata con el sistema de combustible.</p>
        <a href={`tel:${site.phone}`} class="cta__call" data-track="call" data-src="contacto">
          <span class="small muted">Línea directa</span>
          <b>{phoneDisplay(site.phone)} <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14m-6-6 6 6-6 6"/></svg></b>
        </a>
      </div>
    </div>
  </section>

  <section class="sec sec--band">
    <div class="sheet">
      <div class="sec-head">
        <span class="kicker rv">Cobertura</span>
        <h2 class="h-display rv" style="--d:.05s">Los 78 municipios. <span class="grad-text">Verifique el suyo.</span></h2>
      </div>
      <div class="rv" style="--d:.1s; margin-top: clamp(24px, 4vw, 40px);">
        <PRMap />
      </div>
    </div>
  </section>
</Base>

<style>
  .cover { padding-block: clamp(56px, 8vw, 110px) clamp(20px, 3vw, 40px); }
  .cover h1 { margin-top: 18px; }
  .cover .lede { margin-top: 16px; max-width: 48ch; }
  .sec--tightop { padding-top: clamp(24px, 4vw, 56px); }

  .cta { display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); gap: clamp(32px, 5vw, 80px); align-items: start; }
  .cta__whatsapp {
    position: relative;
    overflow: hidden;
    padding: clamp(28px, 4vw, 48px);
    background: radial-gradient(600px 280px at 100% 0%, rgba(37, 211, 102, 0.2), transparent 58%), rgba(148, 170, 210, 0.06);
  }
  .cta__wa-label { display: inline-flex; align-items: center; gap: 9px; color: var(--wa); font-size: 0.78rem; font-weight: 900; letter-spacing: 0.12em; text-transform: uppercase; }
  .cta__wa-label i { width: 8px; height: 8px; border-radius: 50%; background: var(--wa); box-shadow: 0 0 12px var(--wa); animation: pulse 2.2s ease-in-out infinite; }
  .cta__whatsapp h2, .cta__secondary h2 { margin-top: 18px; font-size: clamp(1.7rem, 1.25rem + 1.5vw, 2.4rem); }
  .cta__whatsapp p, .cta__secondary p { margin-top: 14px; }
  .cta__wa-btn { width: 100%; margin-top: 26px; min-height: 60px; }
  .cta__response { display: block; margin-top: 13px; color: var(--ink-70); text-align: center; font-weight: 700; }
  .cta__secondary { padding-block: clamp(12px, 2vw, 24px); }
  .cta__call { display: flex; flex-direction: column; gap: 5px; margin-top: 28px; padding: 20px 4px; color: var(--ink); text-decoration: none; border-block: 1px solid var(--line); transition: padding-left 0.25s var(--ease); }
  .cta__call:hover { padding-left: 12px; }
  .cta__call b { display: inline-flex; align-items: center; gap: 12px; font-family: var(--f-display); font-size: clamp(1.35rem, 2.2vw, 1.8rem); overflow-wrap: anywhere; }
  .cta__call svg { width: 20px; height: 20px; color: var(--ambar); transition: transform 0.25s var(--ease); }
  .cta__call:hover b { color: var(--ambar); }
  .cta__call:hover svg { transform: translateX(6px); }
  @media (max-width: 900px) { .cta { grid-template-columns: 1fr; } }

  .sec--band {
    background:
      radial-gradient(1000px 500px at 80% -10%, rgba(47, 107, 255, 0.12), transparent 60%),
      linear-gradient(180deg, var(--bg-2), var(--bg));
    border-block: 1px solid var(--line);
  }
</style>
