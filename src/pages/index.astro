---
import Base from '../layouts/Base.astro';
import Ticker from '../components/Ticker.astro';
import BeforeAfter from '../components/BeforeAfter.astro';
import LeadForm from '../components/LeadForm.astro';
import PRMap from '../components/PRMap.astro';
import { site, waLink, phoneDisplay, services, steps, industries, projects, stats } from '../lib/site';
import { Image } from 'astro:assets';
import { img } from '../lib/images';
import hero from '../assets/img/hero-generator.jpg';
---
<Base
  title="Blue Coast Developers | Limpieza de Tanques y Pulido de Combustible Diesel en Puerto Rico"
  description="Gestion integral de combustible diesel en Puerto Rico: limpieza de tanques, pulido de combustible y mantenimiento de generadores. Protegemos su energia de respaldo. Respuesta en minutos."
  transparentHeader={true}
  motion={true}
>
  <!-- HERO -->
  <section class="hero">
    <div class="hero__bg">
      <Image src={hero} alt="Generador diesel industrial en sala de maquinas" sizes="100vw" widths={[640, 1024, 1600, 2000]} format="webp" loading="eager" fetchpriority="high" />
    </div>
    <div class="container hero__in">
      <h1 class="display hero__title">Protegemos sus generadores para que arranquen <span class="gold">cuando mas los necesita</span></h1>
      <p class="lead hero__sub">Limpieza de tanques, pulido de combustible y mantenimiento preventivo en todo Puerto Rico. 15+ anos protegiendo los sistemas de respaldo de hospitales, industrias y condominios.</p>
      <div class="hero__cta">
        <a href={waLink()} target="_blank" rel="noopener" class="btn btn--wa btn--lg" data-track="whatsapp" data-src="hero">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.945C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 0 1 8.413 3.488 11.82 11.82 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zM6.6 20.2c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.82 9.82 0 0 0 1.523 5.26l-.999 3.648 3.465-.81z"/></svg>
          Escribir por WhatsApp
        </a>
        <a href={`tel:${site.phone}`} class="btn btn--ghost btn--lg" data-track="call" data-src="hero">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Llamar &middot; {phoneDisplay(site.phone)}
        </a>
      </div>
      <div class="hero__stats">
        <div class="hstat"><b>+15</b><span>anos de experiencia</span></div>
        <div class="hstat"><b>500+</b><span>tanques intervenidos</span></div>
        <div class="hstat"><b>93K</b><span>galones, mayor proyecto</span></div>
      </div>
    </div>
    <a href="#servicios" class="hero__scroll" aria-label="Desplazar"><span></span></a>
  </section>

  <Ticker />

  <!-- CLIENTS -->
  <section class="section section--tight">
    <div class="container">
      <p class="eyebrow" style="justify-content:center;display:flex;">Confian en nosotros</p>
      <div class="clients">
        <span>Hospital Auxilio Mutuo</span><span>Boston Scientific</span><span>Hospital de Damas</span><span>Torre del Cardenal</span><span>Paulson AGI</span>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="section section--alt" id="servicios">
    <div class="container">
      <div class="section-head reveal">
        <h2 class="display">Todo el ciclo de confiabilidad del combustible</h2>
        <p class="muted">Del analisis del diesel a la rehabilitacion completa del tanque, en un solo equipo.</p>
      </div>
      <div class="svc">
        {services.map((s) => (
          <article class="svc__row reveal">
            <span class="svc__n">{s.n}</span>
            <h3 class="svc__t">{s.title}</h3>
            <p class="svc__d muted">{s.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- SIGNATURE: before/after + contamination -->
  <section class="section">
    <div class="container sig">
      <div class="sig__media reveal"><BeforeAfter /></div>
      <div class="sig__copy reveal">
        <h2 class="display">El diesel almacenado se degrada. Nosotros lo devolvemos listo.</h2>
        <p class="muted">Arrastre para ver la diferencia. Con el tiempo el combustible se separa en capas: solo la de arriba esta lista para operar.</p>
        <ul class="layers">
          <li><span class="sw" style="--c:#d8a93c"></span><div><b>Combustible limpio</b> &mdash; la unica capa lista para operar.</div></li>
          <li><span class="sw" style="--c:#5a93ad"></span><div><b>Agua por condensacion</b> &mdash; corrosion y bacterias.</div></li>
          <li><span class="sw" style="--c:#7d5e34"></span><div><b>Sedimentos</b> &mdash; tapan filtros e inyectores.</div></li>
          <li><span class="sw" style="--c:#241c12"></span><div><b>Lodo (sludge)</b> &mdash; obstruye todo el sistema.</div></li>
        </ul>
        <a href="/contacto" class="btn btn--ghost">Solicitar una evaluacion</a>
      </div>
    </div>
  </section>

  <!-- COVERAGE MAP -->
  <section class="section--alt">
    <div class="container">
      <PRMap />
    </div>
  </section>

  <!-- PROCESS -->
  <section class="section">
    <div class="container">
      <div class="section-head reveal">
        <h2 class="display">Cuatro pasos, una sola promesa</h2>
      </div>
      <div class="proc">
        {steps.map((s) => (
          <div class="proc__step reveal">
            <span class="proc__n">{s.n}</span>
            <h3 class="proc__t">{s.title}</h3>
            <p class="muted">{s.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="section section--alt">
    <div class="container stats">
      {stats.map((s) => (
        <div class="stat reveal"><b class="display">{s.big}</b><span class="muted">{s.label}</span></div>
      ))}
    </div>
  </section>

  <!-- INDUSTRIES -->
  <section class="section">
    <div class="container">
      <div class="section-head reveal">
        <h2 class="display">Operaciones criticas que no pueden detenerse</h2>
      </div>
      <ul class="inds">
        {industries.map((i) => (
          <li class="ind reveal"><span class="ind__t">{i}</span></li>
        ))}
      </ul>
    </div>
  </section>

  <!-- PROJECTS -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-head reveal">
        <h2 class="display">Proyectos reales en Puerto Rico</h2>
      </div>
      <div class="proj">
        <a href="/trabajos" class="proj__feat reveal">
          <Image src={img(projects[0].img)} alt={`${projects[0].client} — tanque diesel`} widths={[800, 1400]} sizes="(max-width: 900px) 100vw, 60vw" format="webp" loading="lazy" />
          <div class="proj__feat-copy">
            <span class="proj__cap">{projects[0].cap}</span>
            <h3 class="proj__t">{projects[0].client}</h3>
            <p class="proj__loc">{projects[0].loc}</p>
            <p class="muted">{projects[0].desc}</p>
          </div>
        </a>
        <div class="proj__rest">
          {projects.slice(1).map((p) => (
            <a href="/trabajos" class="proj__item reveal">
              <div class="proj__img"><Image src={img(p.img)} alt={`${p.client} — tanque diesel`} widths={[400, 800]} sizes="(max-width: 760px) 100vw, 33vw" format="webp" loading="lazy" /><span class="proj__cap">{p.cap}</span></div>
              <h3 class="proj__t">{p.client}</h3>
              <p class="proj__loc">{p.loc}</p>
            </a>
          ))}
        </div>
      </div>
      <div class="proj__more reveal"><a href="/trabajos" class="btn btn--ghost">Ver todos los trabajos</a></div>
    </div>
  </section>

  <!-- LEAD CTA -->
  <section class="section cta" id="contacto">
    <div class="container cta__grid">
      <div class="cta__copy reveal">
        <h2 class="display">No espere al proximo apagon para descubrir un problema en su tanque</h2>
        <p class="muted">Identificamos contaminacion antes de que detenga su operacion. Respondemos en minutos.</p>
        <div class="cta__contacts">
          <a href={`tel:${site.phone}`} class="cta__contact" data-track="call" data-src="cta">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <span><i>Llamar</i><b>{phoneDisplay(site.phone)}</b></span>
          </a>
          <a href={waLink()} target="_blank" rel="noopener" class="cta__contact" data-track="whatsapp" data-src="cta">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.945C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 0 1 8.413 3.488 11.82 11.82 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zM6.6 20.2c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.82 9.82 0 0 0 1.523 5.26l-.999 3.648 3.465-.81z"/></svg>
            <span><i>Escribir</i><b>WhatsApp</b></span>
          </a>
        </div>
      </div>
      <div class="cta__form reveal">
        <LeadForm id="lead-home" />
      </div>
    </div>
  </section>
</Base>

<style>
  /* HERO */
  .hero { position: relative; min-height: 100svh; display: flex; align-items: center; padding-block: calc(var(--header-h) + 40px) 80px; overflow: hidden; }
  .hero__bg { position: absolute; inset: 0; z-index: -2; }
  .hero__bg img { width: 100%; height: 100%; object-fit: cover; }
  .hero::after { content: ''; position: absolute; inset: 0; z-index: -1; background: linear-gradient(100deg, var(--navy-900) 8%, rgba(6,14,23,0.82) 42%, rgba(6,14,23,0.35) 100%), linear-gradient(0deg, var(--navy) 2%, transparent 30%); }
  .hero__in { max-width: 880px; }
  .hero__title { font-size: clamp(2.6rem, 1.4rem + 6vw, 6rem); margin: 22px 0 0; max-width: 16ch; }
  .hero__sub { margin: 22px 0 0; max-width: 56ch; }
  .hero__cta { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 32px; }
  .hero__stats { display: flex; flex-wrap: wrap; gap: clamp(20px, 4vw, 44px); margin-top: 36px; }
  .hstat { display: flex; flex-direction: column; gap: 5px; padding-left: clamp(16px, 3vw, 30px); border-left: 1px solid var(--rule-gold); }
  .hstat:first-child { padding-left: 0; border-left: 0; }
  .hstat b { font-family: var(--f-display); font-size: clamp(1.7rem, 1.2rem + 1.4vw, 2.2rem); color: var(--gold); line-height: 1; }
  .hstat span { font-family: var(--f-body); font-weight: 600; font-size: 0.66rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--bone-dim); }
  .hero__scroll { position: absolute; left: 50%; bottom: 26px; transform: translateX(-50%); width: 26px; height: 42px; border: 1px solid var(--line-strong); border-radius: 14px; display: grid; place-items: start center; padding-top: 8px; }
  .hero__scroll span { width: 3px; height: 8px; background: var(--gold); border-radius: 2px; animation: scroll 1.7s var(--ease) infinite; }
  @keyframes scroll { 0% { opacity: 0; transform: translateY(-2px); } 40% { opacity: 1; } 100% { opacity: 0; transform: translateY(12px); } }
  @media (max-width: 940px) { .hero__scroll { display: none; } }

  /* CLIENTS */
  .clients { display: flex; flex-wrap: wrap; justify-content: center; gap: 14px 40px; margin-top: 24px; }
  .clients span { font-family: var(--f-display); text-transform: uppercase; font-size: clamp(1rem, 0.8rem + 1vw, 1.5rem); color: var(--bone-faint); letter-spacing: 0.02em; transition: color 0.2s; }
  .clients span:hover { color: var(--bone); }

  /* SERVICES */
  .svc { margin-top: clamp(36px, 5vw, 54px); border-top: 1px solid var(--line); }
  .svc__row { display: grid; grid-template-columns: 60px minmax(190px, 1fr) 1.7fr; gap: clamp(14px, 3vw, 46px); align-items: start; padding: clamp(26px, 3vw, 38px) 0; border-bottom: 1px solid var(--line); transition: background 0.25s; }
  .svc__row:hover { background: var(--navy-deep); }
  .svc__n { font-family: var(--f-mono); font-size: 0.82rem; letter-spacing: 0.1em; color: var(--gold); padding-top: 8px; }
  .svc__t { font-family: var(--f-display); text-transform: uppercase; font-size: 1.35rem; line-height: 1.05; margin: 0; }
  .svc__d { margin: 0; }
  @media (max-width: 760px) {
    .svc__row { grid-template-columns: auto 1fr; column-gap: 16px; row-gap: 8px; }
    .svc__n { grid-column: 1; grid-row: 1 / span 2; }
    .svc__t { grid-column: 2; grid-row: 1; }
    .svc__d { grid-column: 2; grid-row: 2; }
  }

  /* SIGNATURE */
  .sig { display: grid; grid-template-columns: 1.05fr 0.95fr; gap: clamp(28px, 5vw, 70px); align-items: center; }
  .sig__copy .display { margin: 16px 0; }
  .layers { list-style: none; margin: 24px 0; padding: 0; display: flex; flex-direction: column; gap: 14px; }
  .layers li { display: flex; gap: 13px; align-items: flex-start; font-size: var(--step--1); }
  .layers .sw { width: 16px; height: 16px; border-radius: 3px; background: var(--c); margin-top: 3px; flex: none; border: 1px solid var(--line-strong); }
  @media (max-width: 860px) { .sig { grid-template-columns: 1fr; } }

  /* PROCESS */
  .proc { display: grid; grid-template-columns: repeat(4, 1fr); gap: 28px; margin-top: 50px; }
  .proc__step { border-top: 2px solid var(--rule-gold); padding-top: 20px; }
  .proc__n { font-family: var(--f-display); font-size: 2.4rem; color: var(--gold); line-height: 1; }
  .proc__t { font-family: var(--f-display); text-transform: uppercase; font-size: 1.1rem; margin: 12px 0 10px; }
  @media (max-width: 860px) { .proc { grid-template-columns: 1fr 1fr; gap: 22px; } }
  @media (max-width: 460px) { .proc { grid-template-columns: 1fr; } }

  /* STATS */
  .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 28px; text-align: center; }
  .stat b { display: block; font-size: clamp(2.6rem, 1.6rem + 4vw, 4.6rem); color: var(--gold); line-height: 1; }
  .stat span { display: block; margin-top: 12px; font-family: var(--f-body); font-weight: 600; font-size: 0.76rem; letter-spacing: 0.06em; text-transform: uppercase; }
  @media (max-width: 760px) { .stats { grid-template-columns: 1fr 1fr; gap: 36px 20px; } }

  /* INDUSTRIES */
  .inds { display: flex; flex-wrap: wrap; align-items: baseline; margin-top: clamp(32px, 4vw, 48px); list-style: none; padding: 0; }
  .ind { display: inline-flex; align-items: baseline; }
  .ind__t { font-family: var(--f-display); text-transform: uppercase; font-size: clamp(1.9rem, 1.1rem + 3.4vw, 3.6rem); line-height: 1.08; color: var(--bone); transition: color 0.2s; }
  .ind:hover .ind__t { color: var(--gold); }
  .ind:not(:last-child) .ind__t::after { content: '·'; color: var(--gold); margin: 0 0.38em; }

  /* PROJECTS */
  .proj { margin-top: clamp(36px, 5vw, 50px); }
  .proj__cap { font-family: var(--f-mono); font-size: 0.64rem; letter-spacing: 0.12em; text-transform: uppercase; background: var(--gold); color: var(--navy-900); padding: 5px 9px; }
  .proj__t { font-family: var(--f-display); text-transform: uppercase; font-size: 1.18rem; margin: 0 0 4px; }
  .proj__loc { font-family: var(--f-body); font-weight: 600; font-size: 0.7rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--gold-deep); margin: 0; }
  /* featured project: text over a tall photo */
  .proj__feat { position: relative; display: block; border-radius: var(--radius); overflow: hidden; min-height: 420px; }
  .proj__feat img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s var(--ease); }
  .proj__feat::after { content: ''; position: absolute; inset: 0; background: linear-gradient(0deg, var(--navy-900) 4%, rgba(4,9,15,0.55) 38%, transparent 70%); }
  .proj__feat:hover img { transform: scale(1.04); }
  .proj__feat-copy { position: absolute; left: 0; bottom: 0; z-index: 1; padding: clamp(22px, 3vw, 36px); max-width: 56ch; }
  .proj__feat-copy .proj__cap { position: absolute; top: clamp(22px, 3vw, 36px); left: clamp(22px, 3vw, 36px); }
  .proj__feat-copy .proj__t { font-size: clamp(1.5rem, 1rem + 1.8vw, 2.4rem); margin-top: 10px; }
  .proj__feat-copy .proj__loc { margin-bottom: 10px; }
  /* supporting row: image-led, no boxed body */
  .proj__rest { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(14px, 2vw, 22px); margin-top: clamp(14px, 2vw, 22px); }
  .proj__item { display: block; }
  .proj__img { position: relative; aspect-ratio: 4/3; overflow: hidden; border-radius: var(--radius); }
  .proj__img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s var(--ease); }
  .proj__item:hover .proj__img img { transform: scale(1.05); }
  .proj__img .proj__cap { position: absolute; top: 10px; left: 10px; }
  .proj__item .proj__t { font-size: 1.05rem; margin: 14px 0 3px; }
  .proj__more { margin-top: 36px; }
  @media (max-width: 760px) { .proj__rest { grid-template-columns: 1fr; } .proj__feat { min-height: 340px; } }

  /* CTA */
  .cta { background: linear-gradient(180deg, var(--navy-deep), var(--navy-900)); }
  .cta__grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(30px, 5vw, 64px); align-items: center; }
  .cta__copy .display { margin: 16px 0; }
  .cta__contacts { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 26px; }
  .cta__contact { display: inline-flex; align-items: center; gap: 13px; padding: 14px 20px; border: 1px solid var(--line-strong); border-radius: var(--radius); transition: border-color 0.2s; }
  .cta__contact:hover { border-color: var(--gold); }
  .cta__contact svg { width: 22px; height: 22px; color: var(--gold); }
  .cta__contact i { display: block; font-family: var(--f-body); font-weight: 600; font-size: 0.66rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--bone-dim); }
  .cta__contact b { display: block; font-size: 1.05rem; }
  .cta__form { background: var(--surface); border: 1px solid var(--line-strong); border-radius: var(--radius); padding: clamp(24px, 3vw, 36px); }
  @media (max-width: 860px) { .cta__grid { grid-template-columns: 1fr; } }
</style>
