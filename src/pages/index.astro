---
import Base from '../layouts/Base.astro';
import JarSlider from '../components/JarSlider.astro';
import MuestraBanner from '../components/MuestraBanner.astro';
import TankDemo from '../components/TankDemo.astro';
import IlloLimpieza from '../components/illos/IlloLimpieza.astro';
import IlloPulido from '../components/illos/IlloPulido.astro';
import IlloPreventivo from '../components/illos/IlloPreventivo.astro';
import IlloSistemas from '../components/illos/IlloSistemas.astro';
import IlloDique from '../components/illos/IlloDique.astro';
import { site, waLink, waMsg, phoneDisplay, servicios, serviciosLista, pasos, confianza } from '../lib/site';
import { Image } from 'astro:assets';

import heroImg from '../assets/img/hero-bcd-drive.jpg';
import fotoDamas from '../assets/img/field/hospital-damas-ponce-2.jpg';
import fotoAuxilio from '../assets/img/field/hospital-auxilio-mutuo.jpg';
import fotoBoston from '../assets/img/field/boston-scientific.jpg';
import fotoTorre from '../assets/img/field/torre-del-cardenal.jpg';
import fotoCayey from '../assets/img/field/hospital-menonita-cayey.jpg';

const galeria = [
  { img: fotoAuxilio, t: 'Proyecto hospitalario', d: 'San Juan · 20,000 gal' },
  { img: fotoBoston, t: 'Proyecto farmacéutico', d: 'Dorado · 20,000 gal' },
  { img: fotoTorre, t: 'Proyecto de condominio', d: '6,000 gal' },
  { img: fotoCayey, t: 'Proyecto hospitalario', d: 'Cayey · 30,000 gal' },
];
---
<Base
  title="BCD Diesel | Limpieza de tanques y pulido de diésel en Puerto Rico"
  description="Limpieza de tanques diésel, pulido de combustible y mantenimiento de generadores en los 78 municipios de Puerto Rico. Hospitales, condominios, supermercados, espacios comerciales e industria. Respondemos en minutos, 24/7."
>
  <!-- HERO -->
  <section class="hero" data-hero>
    <div class="hero__bg" aria-hidden="true">
      <Image src={heroImg} alt="" widths={[800, 1280, 1800]} sizes="100vw" format="webp" loading="eager" fetchpriority="high" />
      <div class="hero__shade"></div>
      <div class="hero__glow"></div>
    </div>

    <div class="sheet hero__in">
      <div class="hero__copy">
        <p class="hero__status rv"><i aria-hidden="true"></i> Atendemos 24/7 en toda la isla — respondemos en minutos</p>
        <h1 class="h-display rv" style="--d:.06s">
          Su generador arranca.
          <span class="grad-text">Del diésel nos encargamos nosotros.</span>
        </h1>
        <p class="lede rv" style="--d:.12s">
          Limpieza de tanques, pulido de combustible y mantenimiento preventivo para
          hospitales, condominios, supermercados, espacios comerciales e industria en Puerto Rico.
        </p>
        <div class="hero__cta rv" style="--d:.18s">
          <a href={waLink(waMsg.muestra)} target="_blank" rel="noopener" class="btn btn-wa" data-track="whatsapp" data-src="hero">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.945C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 0 1 8.413 3.488 11.82 11.82 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zM6.6 20.2c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.82 9.82 0 0 0 1.523 5.26l-.999 3.648 3.465-.81z"/></svg>
            Pedir muestra gratis
          </a>
          <a href={`tel:${site.phone}`} class="btn btn-glass" data-track="call" data-src="hero">
            Llamar · {phoneDisplay(site.phone)}
          </a>
        </div>
        <p class="hero__oferta rv" style="--d:.21s">
          <b>Muestra gratis:</b> usted ve el estado de su combustible, sin compromiso.
        </p>
        <p class="hero__record muted rv" style="--d:.24s">
          Más de 15 años y <b>2,000+</b> tanques intervenidos en los 78 municipios —
          desde condominios hasta proyectos de <b>93,000 galones</b>.
        </p>
      </div>
    </div>

    <div class="hero__trust">
      <div class="sheet hero__trust-in">
        <span class="small muted hero__trust-label">Confían en nosotros</span>
        <div class="hero__trust-metrics">
          {confianza.map((c) => (
            <span><b>{c.big}</b> {c.label}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- DEMO: DENTRO DEL TANQUE -->
  <section class="sec sec-demo" id="demo">
    <div class="sheet demo">
      <div class="demo__copy">
        <span class="kicker rv">Dentro de su tanque</span>
        <h2 class="h-display rv" style="--d:.05s">Un tanque «lleno» <span class="grad-text">no es un tanque listo.</span></h2>
        <p class="lede rv" style="--d:.1s">
          Con los años, el diésel almacenado se separa en capas: agua, sedimento
          y lodo (sludge) que tapa los filtros justo cuando el generador arranca.
          Mire lo que hace nuestro ciclo de pulido:
        </p>
        <p class="muted small demo__nota rv" style="--d:.15s">
          Demostración técnica — así trabajamos su tanque en sitio, <span>sin sacarlo de servicio.</span>
        </p>
      </div>
      <div class="demo__stage rv" style="--d:.1s">
        <TankDemo />
      </div>
    </div>
  </section>

  <!-- LA PRUEBA -->
  <section class="sec sec--band">
    <div class="sheet prueba">
      <div class="prueba__copy">
        <span class="kicker rv">La prueba</span>
        <h2 class="h-display rv" style="--d:.05s">El mismo tanque, <span class="grad-text">antes y después</span> del pulido.</h2>
        <p class="lede rv" style="--d:.1s">
          Así entregamos cada trabajo: usted compara la muestra de entrada con el resultado
          final. Los reportes se entregan con la prueba de laboratorio cuando se solicita.
        </p>
        <ul class="prueba__puntos rv" style="--d:.15s">
          <li>Filtración multietapa y separación de agua</li>
          <li>Remoción de lodo y sedimento del fondo</li>
          <li>Prueba de laboratorio disponible con reporte</li>
        </ul>
        <a href={waLink(waMsg.muestra)} target="_blank" rel="noopener" class="btn btn-ambar rv" style="--d:.2s" data-track="whatsapp" data-src="prueba">
          ¿Quiere ver el suyo? Muestra gratis
        </a>
      </div>
      <div class="prueba__media rv" style="--d:.1s">
        <JarSlider />
      </div>
    </div>
  </section>

  <!-- MUESTRA GRATIS -->
  <MuestraBanner />

  <!-- SERVICIOS -->
  <section class="sec" id="servicios">
    <div class="sheet">
      <div class="sec-head">
        <div>
          <span class="kicker rv">Servicios</span>
          <h2 class="h-display rv" style="--d:.05s">Todo el ciclo del combustible, un solo responsable.</h2>
        </div>
        <ul class="servicios-lista rv" style="--d:.1s">
          {serviciosLista.map((s) => <li>{s}</li>)}
        </ul>
      </div>
      <div class="srv">
        {servicios.map((s, i) => (
          <article class:list={['srv__row', 'rv', { 'srv__row--flip': i % 2 === 1 }]} style={`--d:${0.05 * i}s`}>
            <div class="srv__illo">
              {s.code === 'SRV·A' && <IlloLimpieza />}
              {s.code === 'SRV·B' && <IlloPulido />}
              {s.code === 'SRV·C' && <IlloPreventivo />}
              {(s.code === 'SRV·D' || s.code === 'SRV·E') && <IlloSistemas />}
              {s.code === 'SRV·F' && <IlloDique />}
            </div>
            <div class="srv__copy">
              <h3 class="h-display">{s.title}</h3>
              <p class="muted srv__body">{s.body}</p>
              <p class="srv__dato small">{s.dato}</p>
              <a class="srv__link" href={waLink(waMsg.servicio(s.title.toLowerCase()))} target="_blank" rel="noopener" data-track="whatsapp" data-src="servicios">
                Cotizar este servicio
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14m-6-6 6 6-6 6"/></svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- OBRAS -->
  <section class="sec sec--band" id="trabajos">
    <div class="sheet">
      <div class="sec-head">
        <span class="kicker rv">Trabajos reales</span>
        <h2 class="h-display rv" style="--d:.05s">Obra entregada, con capacidad y evidencia.</h2>
        <p class="lede rv" style="--d:.1s">Fotos de nuestros técnicos en el sitio — no banco de imágenes.</p>
      </div>

      <div class="feat edge rv" style="--d:.1s">
        <div class="feat__media">
          <Image src={fotoDamas} alt="Tanque de 93,000 galones en proyecto hospitalario en Ponce" widths={[420, 720]} sizes="(max-width: 860px) 92vw, 40vw" format="webp" loading="lazy" />
        </div>
        <div class="feat__copy">
          <span class="kicker">Proyecto destacado</span>
          <p class="feat__num h-display grad-text">93,000 <small>gal</small></p>
          <h3 class="h-display">Proyecto hospitalario · Ponce</h3>
          <p class="muted">
            Pulido de combustible a gran escala para el sistema de respaldo del hospital.
            El proyecto de mayor capacidad en nuestro registro — empezó con una muestra
            como la que usted puede pedir hoy.
          </p>
          <a href={waLink(waMsg.muestra)} target="_blank" rel="noopener" class="btn btn-ambar" data-track="whatsapp" data-src="obras">
            Pedir mi muestra gratis
          </a>
        </div>
      </div>

      <div class="gal">
        {galeria.map((g, i) => (
          <figure class="gal__item rv" style={`--d:${0.05 * i}s`}>
            <Image src={g.img} alt={`${g.t} — ${g.d}`} widths={[420, 640]} sizes="(max-width: 720px) 92vw, 24vw" format="webp" loading="lazy" />
            <figcaption><b>{g.t}</b><span class="small">{g.d}</span></figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESO -->
  <section class="sec sec--band">
    <div class="sheet">
      <div class="sec-head">
        <span class="kicker rv">Cómo trabajamos</span>
        <h2 class="h-display rv" style="--d:.05s">Cuatro pasos, evidencia incluida.</h2>
      </div>
      <ol class="proc">
        {pasos.map((p, i) => (
          <li class="proc__step rv" style={`--d:${0.06 * i}s`}>
            <span class="proc__n" aria-hidden="true">{p.n}</span>
            <h3 class="h-display">{p.title}</h3>
            <p class="muted small">{p.body}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- SOLICITUD -->
  <section class="sec" id="contacto">
    <div class="sheet cta">
      <div class="cta__copy">
        <span class="kicker rv">Hablemos de su tanque</span>
        <h2 class="h-display rv" style="--d:.05s">No espere al próximo apagón para conocer su tanque.</h2>
        <p class="lede rv" style="--d:.1s">Escríbanos por WhatsApp. Coordinamos la muestra gratis directamente en la conversación.</p>
        <p class="cta__emergency small muted rv" style="--d:.15s">
          ¿Es una emergencia? <a href={`tel:${site.phone}`} data-track="call" data-src="cta">Llame 24/7 al {phoneDisplay(site.phone)}</a>
        </p>
      </div>
      <div class="cta__whatsapp glass rv" style="--d:.1s">
        <span class="cta__wa-label"><i aria-hidden="true"></i> WhatsApp directo</span>
        <h3 class="h-display">Pida su muestra gratis. Sin formularios.</h3>
        <p class="muted">Al abrir el chat solo le pediremos municipio, tipo de facilidad y capacidad aproximada del tanque.</p>
        <a href={waLink(waMsg.muestra)} target="_blank" rel="noopener" class="btn btn-wa cta__wa-btn" data-track="whatsapp" data-src="cta-primary">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.945C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 0 1 8.413 3.488 11.82 11.82 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zM6.6 20.2c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.82 9.82 0 0 0 1.523 5.26l-.999 3.648 3.465-.81z"/></svg>
          Abrir WhatsApp y pedir mi muestra
        </a>
        <span class="small cta__response">Respondemos en minutos · Servicio en los 78 municipios</span>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ---------- HERO ---------- */
  .hero {
    position: relative;
    min-height: calc(100svh - var(--header-h));
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .hero__bg { position: absolute; inset: 0; overflow: clip; }
  .hero__bg img { width: 100%; height: 100%; object-fit: cover; object-position: 68% center; }
  .hero__shade {
    position: absolute; inset: 0;
    background:
      linear-gradient(90deg, rgba(5, 10, 22, 0.97) 22%, rgba(5, 10, 22, 0.78) 46%, rgba(5, 10, 22, 0.25) 78%, rgba(5, 10, 22, 0.55)),
      linear-gradient(0deg, var(--bg) 2%, transparent 26%),
      linear-gradient(180deg, rgba(5, 10, 22, 0.6), transparent 22%);
  }
  .hero__glow {
    position: absolute;
    left: -12%; top: 20%;
    width: 56vw; height: 56vw; max-width: 760px; max-height: 760px;
    background: radial-gradient(closest-side, rgba(47, 107, 255, 0.28), transparent 70%);
    pointer-events: none;
  }
  .hero__in { position: relative; z-index: 2; padding-block: clamp(48px, 7vw, 90px); }
  .hero__copy { max-width: 640px; }
  .hero__copy h1 { margin-top: 22px; }
  .hero__copy .grad-text { display: block; }
  .hero__copy .lede { margin-top: 18px; max-width: 50ch; }
  .hero__cta { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 30px; }
  .hero__status { display: flex; align-items: flex-start; gap: 10px; font-weight: 700; font-size: 0.95rem; color: var(--ink-70); }
  .hero__status i { flex: none; width: 8px; height: 8px; margin-top: 0.5em; border-radius: 50%; background: var(--wa); box-shadow: 0 0 12px var(--wa); animation: pulse 2.2s ease-in-out infinite; }
  .hero__oferta { margin-top: 16px; font-size: 0.95rem; color: var(--ink-70); max-width: 52ch; }
  .hero__oferta b { color: var(--ambar); }
  .hero__record { margin-top: clamp(26px, 4vw, 40px); max-width: 52ch; font-size: 0.98rem; padding-top: 18px; border-top: 1px solid var(--line); }
  .hero__record b { color: var(--ambar); }

  .hero__trust { position: relative; z-index: 2; border-top: 1px solid var(--line); background: rgba(5, 10, 22, 0.55); backdrop-filter: blur(10px); }
  .hero__trust-in { display: flex; flex-direction: column; align-items: center; gap: 14px; padding-block: 16px; }
  .hero__trust-label { letter-spacing: 0.14em; text-transform: uppercase; font-weight: 700; font-size: 0.68rem; }
  .hero__trust-metrics {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 10px;
    width: 100%;
  }
  .hero__trust-metrics span {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 7px;
    min-height: 44px;
    padding: 9px 10px;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: rgba(148, 170, 210, 0.05);
    color: var(--ink-70);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: clamp(0.68rem, 0.62rem + 0.25vw, 0.82rem);
    text-align: center;
  }
  .hero__trust-metrics b {
    font-family: var(--f-display);
    color: var(--ambar);
    font-size: clamp(1.1rem, 0.9rem + 0.9vw, 1.6rem);
    letter-spacing: 0;
  }
  @media (max-width: 820px) { .hero__trust-metrics { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 420px) { .hero__trust-metrics { grid-template-columns: 1fr; } }

  /* ---------- DEMO TANQUE ---------- */
  .sec-demo { padding-top: clamp(26px, 4vw, 56px); }
  .demo { display: grid; grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr); gap: clamp(32px, 5vw, 72px); align-items: center; }
  .demo__copy h2 { margin-top: 16px; }
  .demo__copy .lede { margin-top: 16px; }
  .demo__nota { margin-top: 18px; padding-left: 14px; border-left: 2px solid var(--ambar); }
  .demo__nota span { color: var(--ambar); font-weight: 800; }
  @media (max-width: 920px) { .demo { grid-template-columns: 1fr; } }

  /* ---------- PRUEBA ---------- */
  .prueba { display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); gap: clamp(32px, 5vw, 80px); align-items: center; }
  .prueba__copy h2 { margin-top: 16px; }
  .prueba__copy .lede { margin-top: 16px; }
  .prueba__puntos { list-style: none; padding: 0; margin: 22px 0 28px; display: grid; gap: 12px; }
  .prueba__puntos li { position: relative; padding-left: 30px; color: var(--ink-70); font-weight: 600; }
  .prueba__puntos li::before {
    content: '✓';
    position: absolute; left: 0; top: 0;
    width: 21px; height: 21px;
    display: grid; place-items: center;
    border-radius: 7px;
    font-size: 0.72rem; font-weight: 900;
    background: rgba(255, 176, 58, 0.16);
    color: var(--ambar);
    border: 1px solid rgba(255, 176, 58, 0.4);
  }
  @media (max-width: 900px) { .prueba { grid-template-columns: 1fr; } }

  /* ---------- bandas ---------- */
  .sec--band {
    background:
      radial-gradient(1000px 500px at 80% -10%, rgba(47, 107, 255, 0.12), transparent 60%),
      linear-gradient(180deg, var(--bg-2), var(--bg));
    border-block: 1px solid var(--line);
  }

  /* ---------- SERVICIOS: filas ilustradas, sin cajas ---------- */
  #servicios .sec-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 0.62fr);
    gap: clamp(24px, 5vw, 72px);
    align-items: start;
  }
  .servicios-lista {
    list-style: none;
    margin: 6px 0 0;
    padding: 0;
    display: grid;
    gap: 8px;
    color: var(--ink-70);
    font-weight: 700;
  }
  .servicios-lista li {
    position: relative;
    padding-left: 18px;
  }
  .servicios-lista li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.68em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--ambar);
  }
  @media (max-width: 820px) { #servicios .sec-head { grid-template-columns: 1fr; } }
  .srv { margin-top: clamp(26px, 4vw, 44px); }
  .srv__row {
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr);
    gap: clamp(22px, 4vw, 60px);
    align-items: center;
    padding-block: clamp(26px, 3.5vw, 42px);
    border-top: 1px solid var(--line);
  }
  .srv__row:last-of-type { border-bottom: 1px solid var(--line); }
  .srv__row--flip { grid-template-columns: minmax(0, 1fr) 220px; }
  .srv__row--flip .srv__illo { order: 2; }
  .srv__illo :global(.illo) { width: 100%; max-width: 220px; height: auto; }
  .srv__body { margin-top: 10px; max-width: 56ch; }
  .srv__dato { margin-top: 14px; font-weight: 700; letter-spacing: 0.06em; color: var(--cyan); }
  .srv__link {
    display: inline-flex; align-items: center; gap: 8px;
    margin-top: 16px;
    font-weight: 800; font-size: 0.95rem;
    color: var(--ambar); text-decoration: none;
  }
  .srv__link svg { width: 17px; height: 17px; transition: transform 0.2s var(--ease); }
  .srv__link:hover svg { transform: translateX(4px); }
  @media (max-width: 720px) {
    .srv__row, .srv__row--flip { grid-template-columns: 1fr; gap: 14px; }
    .srv__row--flip .srv__illo { order: 0; }
    .srv__illo { display: flex; justify-content: center; }
    .srv__illo :global(.illo) { max-width: 190px; }
  }

  /* ---------- OBRAS ---------- */
  .feat { display: grid; grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr); gap: 0; margin-top: clamp(30px, 4vw, 48px); overflow: clip; }
  .feat__media { min-height: 340px; position: relative; overflow: clip; }
  .feat__media img { width: 100%; height: 100%; object-fit: cover; filter: saturate(1.08) contrast(1.05); transform: scale(1.02); }
  @media (min-width: 861px) {
    .feat__media::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, transparent 72%, var(--bg-2) 99%);
      pointer-events: none;
    }
  }
  @media (max-width: 860px) {
    .feat__media::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, transparent 72%, var(--bg-2) 99%);
      pointer-events: none;
    }
  }
  .feat__copy { padding: clamp(26px, 4vw, 48px); display: flex; flex-direction: column; align-items: flex-start; gap: 16px; }
  .feat__num { font-size: clamp(2.6rem, 2rem + 3vw, 4.4rem); font-weight: 700; letter-spacing: -0.03em; line-height: 1; }
  .feat__num small { font-size: 0.4em; font-weight: 800; }
  .feat__copy p.muted { max-width: 50ch; }
  @media (max-width: 860px) { .feat { grid-template-columns: 1fr; } .feat__media { min-height: 240px; } }

  .gal { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-top: 18px; }
  .gal__item {
    position: relative;
    margin: 0;
    border-radius: var(--r-md);
    overflow: clip;
    aspect-ratio: 4 / 5;
    background: var(--bg);
