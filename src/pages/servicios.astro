---
import Base from '../layouts/Base.astro';
import MuestraBanner from '../components/MuestraBanner.astro';
import IlloLimpieza from '../components/illos/IlloLimpieza.astro';
import IlloPulido from '../components/illos/IlloPulido.astro';
import IlloPreventivo from '../components/illos/IlloPreventivo.astro';
import IlloSistemas from '../components/illos/IlloSistemas.astro';
import { site, waLink, waMsg, phoneDisplay, servicios, pasos } from '../lib/site';

const planes = [
  {
    name: 'Plan Inspección',
    sub: 'Visibilidad continua de su combustible',
    feats: ['Muestreo de combustible', 'Reporte de condición anual', 'Recomendaciones por escrito'],
    rec: false,
  },
  {
    name: 'Plan Semestral',
    sub: 'Mantenimiento programado durante el año',
    feats: ['Pulido y limpieza programada', 'Dos visitas al año', 'Atención prioritaria'],
    rec: true,
  },
  {
    name: 'Plan Cumplimiento',
    sub: 'Para hospitales e industria regulada',
    feats: ['Documentación lista para auditoría (NFPA 110)', 'Respuesta prioritaria', 'Historial y evidencia de cada servicio'],
    rec: false,
  },
];
---
<Base
  title="Servicios | Blue Coast Developers — Limpieza de tanques y pulido de diésel en Puerto Rico"
  description="Limpieza de tanques diésel, pulido de combustible, mantenimiento preventivo y sistemas de combustible para generadores. Planes de mantenimiento para hospitales, condominios e industria en Puerto Rico."
>
  <section class="cover" data-hero>
    <div class="sheet">
      <span class="kicker rv">Servicios</span>
      <h1 class="h-display rv" style="--d:.05s">Todo el ciclo del combustible, <span class="grad-text">un solo responsable.</span></h1>
      <p class="lede rv" style="--d:.1s">
        Del análisis del diésel a la rehabilitación completa del tanque. Cada servicio
        indica exactamente qué incluye, sin letra pequeña.
      </p>
      <div class="cover__cta rv" style="--d:.15s">
        <a href={waLink(waMsg.muestra)} target="_blank" rel="noopener" class="btn btn-wa" data-track="whatsapp" data-src="servicios-hero">Pedir muestra gratis</a>
        <a href={`tel:${site.phone}`} class="btn btn-glass" data-track="call" data-src="servicios-hero">Llamar · {phoneDisplay(site.phone)}</a>
      </div>
    </div>
  </section>

  <section class="sec sec--tightop">
    <div class="sheet">
      <div class="srv">
        {servicios.map((s, i) => (
          <article class:list={['srv__row', 'rv', { 'srv__row--flip': i % 2 === 1 }]} style={`--d:${0.05 * i}s`}>
            <div class="srv__illo">
              {s.code === 'SRV·A' && <IlloLimpieza />}
              {s.code === 'SRV·B' && <IlloPulido />}
              {s.code === 'SRV·C' && <IlloPreventivo />}
              {s.code === 'SRV·D' && <IlloSistemas />}
            </div>
            <div>
              <h2 class="h-display srv__t">{s.title}</h2>
              <p class="muted srv__body">{s.body}</p>
              <ul class="srv__incl">
                {s.incluye.map((d) => <li>{d}</li>)}
              </ul>
              <p class="srv__dato small">{s.dato}</p>
              <a class="srv__link" href={waLink(waMsg.servicio(s.title.toLowerCase()))} target="_blank" rel="noopener" data-track="whatsapp" data-src="servicios">
                Cotizar este servicio
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14m-6-6 6 6-6 6"/></svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="sec sec--band">
    <div class="sheet">
      <div class="sec-head">
        <span class="kicker rv">Planes de mantenimiento</span>
        <h2 class="h-display rv" style="--d:.05s">Planes que no dependen de la suerte.</h2>
      </div>
      <div class="planes edge rv" style="--d:.1s">
        {planes.map((p) => (
          <article class:list={['plan', { 'plan--rec': p.rec }]}>
            {p.rec && <span class="plan__badge">Recomendado</span>}
            <h3 class="h-display plan__name">{p.name}</h3>
            <p class="small muted plan__sub">{p.sub}</p>
            <ul class="plan__feats">
              {p.feats.map((f) => <li>{f}</li>)}
            </ul>
            <a href={waLink(waMsg.plan(p.name))} target="_blank" rel="noopener" class:list={['btn', p.rec ? 'btn-ambar' : 'btn-glass']} data-track="whatsapp" data-src="planes">
              Solicitar este plan
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="sec">
    <div class="sheet">
      <div class="sec-head">
        <span class="kicker rv">Cómo trabajamos</span>
        <h2 class="h-display rv" style="--d:.05s">Cuatro pasos, evidencia incluida.</h2>
      </div>
      <ol class="proc">
        {pasos.map((p, i) => (
          <li class="proc__step rv" style={`--d:${0.06 * i}s`}>
            <span class="proc__n" aria-hidden="true">{p.n}</span>
            <h3 class="h-display">{p.title}</h3>
            <p class="muted small">{p.body}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <MuestraBanner />
</Base>

<style>
  .cover { padding-block: clamp(56px, 8vw, 110px) clamp(20px, 3vw, 40px); }
  .cover h1 { margin-top: 18px; max-width: 22ch; }
  .cover .lede { margin-top: 16px; max-width: 56ch; }
  .cover__cta { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 28px; }
  .sec--tightop { padding-top: clamp(24px, 4vw, 56px); }

  /* filas de servicio ilustradas (versión expandida) */
  .srv__row {
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr);
    gap: clamp(22px, 4vw, 60px);
    align-items: center;
    padding-block: clamp(28px, 4vw, 48px);
    border-top: 1px solid var(--line);
  }
  .srv__row:last-of-type { border-bottom: 1px solid var(--line); }
  .srv__row--flip { grid-template-columns: minmax(0, 1fr) 220px; }
  .srv__row--flip .srv__illo { order: 2; }
  .srv__illo :global(.illo) { width: 100%; max-width: 220px; height: auto; }
  .srv__t { font-size: clamp(1.4rem, 1.1rem + 1.4vw, 2.1rem); }
  .srv__body { margin-top: 10px; max-width: 56ch; }
  .srv__incl { list-style: none; margin: 16px 0 0; padding: 0; display: grid; gap: 9px; }
  .srv__incl li { position: relative; padding-left: 26px; color: var(--ink-70); font-size: 0.95rem; }
  .srv__incl li::before {
    content: '✓';
    position: absolute; left: 0; top: 1px;
    width: 18px; height: 18px;
    display: grid; place-items: center;
    border-radius: 6px;
    font-size: 0.62rem; font-weight: 900;
    background: rgba(255, 176, 58, 0.14);
    color: var(--ambar);
    border: 1px solid rgba(255, 176, 58, 0.35);
  }
  .srv__dato { margin-top: 14px; font-weight: 700; letter-spacing: 0.06em; color: var(--cyan); }
  .srv__link { display: inline-flex; align-items: center; gap: 8px; margin-top: 14px; font-weight: 800; font-size: 0.95rem; color: var(--ambar); text-decoration: none; }
  .srv__link svg { width: 17px; height: 17px; transition: transform 0.2s var(--ease); }
  .srv__link:hover svg { transform: translateX(4px); }
  @media (max-width: 720px) {
    .srv__row, .srv__row--flip { grid-template-columns: 1fr; gap: 14px; }
    .srv__row--flip .srv__illo { order: 0; }
    .srv__illo { display: flex; justify-content: center; }
    .srv__illo :global(.illo) { max-width: 190px; }
  }

  .sec--band {
    background:
      radial-gradient(1000px 500px at 80% -10%, rgba(47, 107, 255, 0.12), transparent 60%),
      linear-gradient(180deg, var(--bg-2), var(--bg));
    border-block: 1px solid var(--line);
  }

  /* planes */
  .planes { display: grid; grid-template-columns: repeat(3, 1fr); margin-top: clamp(28px, 4vw, 44px); overflow: clip; }
  .plan { position: relative; display: flex; flex-direction: column; padding: clamp(24px, 3vw, 38px); border-right: 1px solid var(--line); }
  .plan:last-child { border-right: 0; }
  .plan--rec { background: rgba(255, 176, 58, 0.07); }
  .plan__badge {
    position: absolute; top: 14px; right: 14px;
    font-size: 0.68rem; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--ambar); border: 1px solid rgba(255, 176, 58, 0.5); border-radius: 8px; padding: 5px 10px;
  }
  .plan__name { font-size: 1.3rem; }
  .plan__sub { margin-top: 8px; }
  .plan__feats { list-style: none; margin: 18px 0 22px; padding: 0; flex: 1; display: grid; gap: 10px; align-content: start; }
  .plan__feats li { position: relative; padding-left: 22px; color: var(--ink-70); font-size: 0.95rem; }
  .plan__feats li::before { content: ''; position: absolute; left: 2px; top: 0.6em; width: 10px; height: 2px; border-radius: 2px; background: var(--ambar); }
  @media (max-width: 880px) {
    .planes { grid-template-columns: 1fr; }
    .plan { border-right: 0; border-bottom: 1px solid var(--line); }
    .plan:last-child { border-bottom: 0; }
  }

  /* proceso (mismo patrón del home) */
  .proc { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; margin: clamp(30px, 4vw, 48px) 0 0; padding: 0; list-style: none; }
  .proc__step { position: relative; padding-top: 22px; }
  .proc__step::before { content: ''; position: absolute; top: 0; left: 0; right: 18px; height: 1px; background: var(--line-2); }
  .proc__step::after { content: ''; position: absolute; top: -2px; left: 0; width: 42px; height: 5px; border-radius: 4px; background: linear-gradient(90deg, var(--ambar), var(--ambar-2)); }
  .proc__n { display: inline-grid; place-items: center; width: 42px; height: 42px; border-radius: 50%; border: 1.5px solid rgba(255, 176, 58, 0.55); font-family: var(--f-display); font-weight: 700; font-size: 1.05rem; color: var(--ambar); background: rgba(255, 176, 58, 0.07); margin-bottom: 14px; }
  .proc__step h3 { font-size: 1.1rem; }
  .proc__step p { margin-top: 8px; max-width: 30ch; }
  @media (max-width: 860px) { .proc { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 520px) { .proc { grid-template-columns: 1fr; } }
</style>
