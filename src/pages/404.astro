---
import Base from '../layouts/Base.astro';
import { site, waLink, waMsg, phoneDisplay } from '../lib/site';
---
<Base title="Página no encontrada | Blue Coast Developers" description="La página que busca no existe.">
  <section class="nf" data-hero>
    <div class="sheet nf__in">
      <p class="nf__code h-display grad-text" aria-hidden="true">404</p>
      <h1 class="h-display">Esta página no existe.</h1>
      <p class="lede">El enlace puede estar roto o la página fue movida.</p>
      <div class="nf__cta">
        <a href="/" class="btn btn-ambar">Ir al inicio</a>
        <a href={waLink(waMsg.muestra)} target="_blank" rel="noopener" class="btn btn-wa" data-track="whatsapp" data-src="404">Pedir muestra gratis</a>
        <a href={`tel:${site.phone}`} class="btn btn-glass" data-track="call" data-src="404">Llamar · {phoneDisplay(site.phone)}</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .nf { min-height: 62svh; display: grid; place-items: center; padding-block: clamp(56px, 8vw, 100px); }
  .nf__in { max-width: 640px; display: flex; flex-direction: column; align-items: flex-start; gap: 16px; }
  .nf__code { font-size: clamp(4.5rem, 3rem + 8vw, 9rem); font-weight: 800; line-height: 1; }
  .nf__cta { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 10px; }
</style>
