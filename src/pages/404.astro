---
import Base from '../layouts/Base.astro';
import { site, waLink, phoneDisplay } from '../lib/site';
---
<Base title="Pagina no encontrada | Blue Coast Developers" description="La pagina que busca no existe.">
  <section class="section nf">
    <div class="container nf__in">
      <p class="display nf__code">404</p>
      <h1 class="display">Esta pagina no existe</h1>
      <p class="lead muted">El enlace puede estar roto o la pagina fue movida. Volvamos a terreno firme.</p>
      <div class="nf__cta">
        <a href="/" class="btn btn--gold btn--lg">Ir al inicio</a>
        <a href={`tel:${site.phone}`} class="btn btn--ghost btn--lg" data-track="call" data-src="404">Llamar &middot; {phoneDisplay(site.phone)}</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .nf { min-height: 66svh; display: grid; place-items: center; text-align: center; }
  .nf__in { max-width: 560px; }
  .nf__code { font-size: clamp(5rem, 3rem + 12vw, 11rem); color: var(--gold); line-height: 0.9; }
  .nf .display { margin: 4px 0 16px; }
  .nf__cta { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; margin-top: 28px; }
</style>
