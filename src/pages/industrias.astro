---
import Base from '../layouts/Base.astro';
import MuestraBanner from '../components/MuestraBanner.astro';
import { site, waLink, waMsg, phoneDisplay, sectores } from '../lib/site';

const razones = [
  { title: 'Respuesta rápida', body: 'Cuando ocurre el apagón, su generador no puede esperar. Llegamos rápido para que su operación siga.' },
  { title: 'Técnicos con experiencia', body: 'Más de 15 años y 500+ tanques intervenidos protegiendo sistemas de respaldo en Puerto Rico.' },
  { title: 'Cobertura en toda la isla', body: 'Damos servicio en los 78 municipios, donde sea que operen sus generadores.' },
  { title: 'Cumplimiento y seguridad', body: 'Mantenemos su sistema de respaldo listo y conforme a normas como NFPA 110, con reporte para auditoría.' },
];
---
<Base
  title="Industrias | Blue Coast Developers Puerto Rico"
  description="Hospitales, hoteles, data centers, condominios, supermercados e industria: mantenemos el diésel de las operaciones críticas que no pueden detenerse en Puerto Rico."
>
  <section class="cover" data-hero>
    <div class="sheet">
      <span class="kicker rv">Industrias</span>
      <h1 class="h-display rv" style="--d:.05s">Donde un apagón <span class="grad-text">no es una opción.</span></h1>
      <p class="lede rv" style="--d:.1s">
        Cada sector paga la parada de forma distinta. Protegemos el combustible que
        mantiene su respaldo listo.
      </p>
      <div class="cover__cta rv" style="--d:.15s">
        <a href={waLink(waMsg.muestra)} target="_blank" rel="noopener" class="btn btn-wa" data-track="whatsapp" data-src="industrias-hero">Pedir muestra gratis</a>
        <a href={`tel:${site.phone}`} class="btn btn-glass" data-track="call" data-src="industrias-hero">Llamar · {phoneDisplay(site.phone)}</a>
      </div>
    </div>
  </section>

  <section class="sec sec--tightop">
    <div class="sheet">
      <ol class="sect">
        {sectores.map((s, i) => (
          <li class="sect__row rv" style={`--d:${0.04 * i}s`}>
            <span class="sect__n" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <h2 class="h-display sect__t">{s.name}</h2>
            <p class="muted sect__why">{s.why}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="sec sec--band">
    <div class="sheet">
      <div class="sec-head">
        <span class="kicker rv">Por qué Blue Coast</span>
        <h2 class="h-display rv" style="--d:.05s">El respaldo de su respaldo.</h2>
      </div>
      <div class="raz">
        {razones.map((r, i) => (
          <div class="raz__item rv" style={`--d:${0.05 * i}s`}>
            <h3 class="h-display">{r.title}</h3>
            <p class="muted small">{r.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <MuestraBanner />
</Base>

<style>
  .cover { padding-block: clamp(56px, 8vw, 110px) clamp(20px, 3vw, 40px); }
  .cover h1 { margin-top: 18px; max-width: 20ch; }
  .cover .lede { margin-top: 16px; max-width: 52ch; }
  .cover__cta { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 28px; }
  .sec--tightop { padding-top: clamp(24px, 4vw, 56px); }

  .sect { list-style: none; margin: 0; padding: 0; }
  .sect__row {
    display: grid;
    grid-template-columns: 64px minmax(180px, 0.7fr) 1.3fr;
    gap: clamp(14px, 3vw, 48px);
    align-items: baseline;
    padding-block: clamp(22px, 3vw, 36px);
    border-top: 1px solid var(--line);
    transition: background 0.15s;
  }
  .sect__row:hover { background: rgba(148, 170, 210, 0.04); }
  .sect__row:last-child { border-bottom: 1px solid var(--line); }
  .sect__n { font-family: var(--f-display); font-weight: 700; color: var(--ambar); font-size: 1.05rem; }
  .sect__t { font-size: clamp(1.5rem, 1.1rem + 1.8vw, 2.4rem); margin: 0; }
  .sect__why { margin: 0; max-width: 48ch; }
  @media (max-width: 700px) {
    .sect__row { grid-template-columns: 48px 1fr; }
    .sect__why { grid-column: 2; }
  }

  .sec--band {
    background:
      radial-gradient(1000px 500px at 80% -10%, rgba(47, 107, 255, 0.12), transparent 60%),
      linear-gradient(180deg, var(--bg-2), var(--bg));
    border-block: 1px solid var(--line);
  }
  .raz { display: grid; grid-template-columns: repeat(2, 1fr); gap: clamp(24px, 4vw, 48px); margin-top: clamp(28px, 4vw, 44px); }
  .raz__item { position: relative; padding-top: 20px; }
  .raz__item::before { content: ''; position: absolute; top: 0; left: 0; width: 42px; height: 5px; border-radius: 4px; background: linear-gradient(90deg, var(--ambar), var(--ambar-2)); }
  .raz__item h3 { font-size: 1.2rem; }
  .raz__item p { margin-top: 8px; max-width: 44ch; }
  @media (max-width: 700px) { .raz { grid-template-columns: 1fr; } }
</style>
