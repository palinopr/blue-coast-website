---
// Ilustracion: dique de contencion alrededor de un tanque de diesel.
---
<svg class="illo" viewBox="0 0 180 140" aria-hidden="true">
  <defs>
    <linearGradient id="id-tank" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#2a3c5c" />
      <stop offset="1" stop-color="#141f36" />
    </linearGradient>
    <linearGradient id="id-wall" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#31496c" />
      <stop offset="1" stop-color="#17243e" />
    </linearGradient>
  </defs>

  <ellipse cx="90" cy="112" rx="72" ry="12" fill="#0b1322" opacity=".65" />

  <!-- muro de contencion / dique -->
  <path d="M24 84h132v30H24Z" fill="url(#id-wall)" stroke="#4f6f9f" stroke-width="1.4" />
  <path d="M24 84l18-22h96l18 22Z" fill="#203556" stroke="#4f6f9f" stroke-width="1.4" />
  <path d="M42 62v52M138 62v52" stroke="#5b7db8" stroke-width="1.2" opacity=".65" />
  <path d="M36 94h108" stroke="#8fb2ea" stroke-width="1.2" stroke-dasharray="5 8" opacity=".5" />

  <!-- tanque dentro del dique -->
  <rect x="62" y="30" width="56" height="72" rx="13" fill="url(#id-tank)" stroke="#5b7db8" stroke-width="1.5" />
  <ellipse cx="90" cy="30" rx="28" ry="7" fill="#3d5a84" stroke="#77a0dc" stroke-width="1.1" />
  <rect x="68" y="66" width="44" height="26" rx="7" fill="#7a5a18" />
  <rect x="68" y="60" width="44" height="8" rx="4" fill="#ffb03a" opacity=".9" />
  <text x="90" y="50" text-anchor="middle" font-family="var(--f-ui)" font-size="9" font-weight="800" letter-spacing=".08em" fill="#9fb4d8">TANQUE</text>

  <!-- gota contenida -->
  <path class="gota" d="M134 39c7 10 12 17 12 24a12 12 0 0 1-24 0c0-7 5-14 12-24Z" fill="#ffb03a" opacity=".9" />
  <path d="M131 61c2 4 5 6 9 6" stroke="#fff0c8" stroke-width="2" stroke-linecap="round" opacity=".55" />

  <style>
    .gota { animation: id-pulse 2.2s ease-in-out infinite; transform-origin: center; transform-box: fill-box; }
    @keyframes id-pulse { 0%, 100% { transform: scale(1); opacity: .9; } 50% { transform: scale(.9); opacity: .55; } }
    @media (prefers-reduced-motion: reduce) { .gota { animation: none; } }
  </style>
</svg>
