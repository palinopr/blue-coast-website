---
// Barra de acción móvil: WhatsApp + Llamar siempre a un toque.
import { site, waLink, waMsg } from '../lib/site';
---
<div class="abar" id="abar">
  <a href={waLink(waMsg.muestra)} target="_blank" rel="noopener" class="abar__btn abar__wa" data-track="whatsapp" data-src="actionbar">
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.945C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 0 1 8.413 3.488 11.82 11.82 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zM6.6 20.2c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.82 9.82 0 0 0 1.523 5.26l-.999 3.648 3.465-.81z"/></svg>
    Muestra gratis
  </a>
  <a href={`tel:${site.phone}`} class="abar__btn" data-track="call" data-src="actionbar">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
    Llamar
  </a>
</div>

<style>
  .abar {
    position: fixed;
    left: 12px; right: 12px;
    bottom: max(12px, env(safe-area-inset-bottom));
    z-index: 90;
    display: none;
    gap: 10px;
    padding: 10px;
    border-radius: 18px;
    border: 1px solid var(--line-2);
    background: rgba(10, 18, 38, 0.82);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    box-shadow: 0 18px 50px rgba(2, 6, 18, 0.6);
    translate: 0 130%;
    transition: translate 0.4s var(--ease);
  }
  .abar.is-on { translate: 0 0; }
  @media (max-width: 960px) { .abar { display: flex; } }
  body:has(form :focus) .abar { translate: 0 130%; }

  .abar__btn {
    flex: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5em;
    min-height: 50px;
    border-radius: 12px;
    font-weight: 800;
    font-size: 1rem;
    text-decoration: none;
    color: var(--ink);
    border: 1px solid var(--line-2);
    background: rgba(148, 170, 210, 0.07);
  }
  .abar__btn svg { width: 1.1em; height: 1.1em; }
  .abar__wa { background: var(--wa); border-color: var(--wa); color: #04170b; box-shadow: 0 10px 26px -8px rgba(37, 211, 102, 0.6); }
</style>

<script>
  // Visible tras pasar el héroe; se retira cuando el formulario está en
  // pantalla (para no tapar el botón de enviar) o mientras se escribe.
  const bar = document.getElementById('abar');
  const hero = document.querySelector('[data-hero]');
  const contacto = document.getElementById('contacto');
  if (bar && hero) {
    let pastHero = false;
    let onForm = false;
    const apply = () => bar.classList.toggle('is-on', pastHero && !onForm);
    const ioHero = new IntersectionObserver(([e]) => { pastHero = !e.isIntersecting; apply(); }, { rootMargin: '-90px 0px 0px 0px' });
    ioHero.observe(hero);
    if (contacto) {
      const ioForm = new IntersectionObserver(([e]) => { onForm = e.isIntersecting; apply(); }, { threshold: 0.25 });
      ioForm.observe(contacto);
    }
  } else if (bar) {
    bar.classList.add('is-on');
  }
</script>
