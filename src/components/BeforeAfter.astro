---
import { Image } from 'astro:assets';
import antes from '../assets/img/fuel-antes.jpg';
import despues from '../assets/img/fuel-despues.jpg';
---
<div class="ba" id="ba" role="group" aria-label="Comparacion de combustible antes y despues">
  <Image class="ba__img" src={despues} alt="Muestra de combustible diesel limpio despues del pulido" widths={[600, 1000, 1400]} sizes="(max-width: 860px) 100vw, 50vw" format="webp" loading="lazy" draggable={false} />
  <div class="ba__clip" data-clip>
    <Image class="ba__img" src={antes} alt="Muestra de combustible diesel contaminado antes del servicio" widths={[600, 1000, 1400]} sizes="100vw" format="webp" loading="lazy" draggable={false} />
  </div>
  <span class="ba__tag ba__tag--before">Antes</span>
  <span class="ba__tag ba__tag--after">Despues</span>
  <button class="ba__handle" data-handle aria-label="Arrastrar para comparar">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6 3 12l6 6M15 6l6 6-6 6"/></svg>
  </button>
</div>

<style>
  .ba { position: relative; aspect-ratio: 16 / 10; border: 1px solid var(--line-strong); border-radius: var(--radius); overflow: hidden; user-select: none; touch-action: none; }
  .ba__img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .ba__clip { position: absolute; inset: 0; width: 50%; overflow: hidden; border-right: 2px solid var(--gold); }
  .ba__clip .ba__img { width: 100vw; max-width: none; }
  .ba__tag { position: absolute; top: 14px; font-family: var(--f-mono); font-size: 0.66rem; letter-spacing: 0.18em; text-transform: uppercase; padding: 5px 10px; border-radius: 2px; background: rgba(4, 9, 15, 0.78); color: var(--bone); }
  .ba__tag--before { left: 14px; }
  .ba__tag--after { right: 14px; color: var(--gold); }
  .ba__handle { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 46px; height: 46px; border-radius: 50%; background: var(--gold); color: var(--navy-900); border: 0; display: grid; place-items: center; box-shadow: 0 6px 20px rgba(0,0,0,0.4); cursor: ew-resize; }
  .ba__handle svg { width: 20px; height: 20px; }
</style>

<script>
  const ba = document.getElementById('ba');
  if (ba) {
    const clip = ba.querySelector('[data-clip]') as HTMLElement;
    const handle = ba.querySelector('[data-handle]') as HTMLElement;
    let drag = false;
    const set = (clientX: number) => {
      const r = ba.getBoundingClientRect();
      const p = Math.min(Math.max((clientX - r.left) / r.width, 0.02), 0.98);
      clip.style.width = p * 100 + '%';
      handle.style.left = p * 100 + '%';
    };
    const down = (e: PointerEvent) => { drag = true; ba.setPointerCapture(e.pointerId); set(e.clientX); };
    ba.addEventListener('pointerdown', down);
    ba.addEventListener('pointermove', (e) => drag && set(e.clientX));
    ba.addEventListener('pointerup', () => (drag = false));
    ba.addEventListener('pointercancel', () => (drag = false));
  }
</script>
