---
// Mapa de cobertura de Puerto Rico: 78 municipios (geometría TIGER).
// Municipios con obra entregada brillan en ámbar. El buscador cualifica el
// lead: resalta el municipio y reescribe el WhatsApp con el mensaje listo.
import { PR_VIEWBOX, MUNICIPIOS, COVERED_MUNIS, COVERED_COUNT, PROJECT_COUNT } from '../lib/prmap';
import { waLink, waMsg } from '../lib/site';
---
<div class="prmap" data-prmap>
  <div class="prmap__search glass">
    <label class="small muted" for="muni-q">¿Cubrimos su municipio? Sí — verifíquelo:</label>
    <div class="prmap__row">
      <input id="muni-q" list="munis-list" type="text" placeholder="Escriba su municipio — p. ej. Ponce" autocomplete="off" data-muni-input />
      <datalist id="munis-list">
        {MUNICIPIOS.map((m) => <option value={m.name} />)}
      </datalist>
      <a href={waLink(waMsg.cobertura())} target="_blank" rel="noopener" class="btn btn-wa" data-track="whatsapp" data-src="cobertura" data-muni-cta>
        WhatsApp
      </a>
    </div>
    <p class="small prmap__readout" data-muni-readout aria-live="polite">
      {COVERED_COUNT} municipios con obra entregada · {PROJECT_COUNT} trabajos realizados
    </p>
  </div>

  <figure class="prmap__fig">
    <div class="prmap__scroll">
      <svg viewBox={PR_VIEWBOX} class="prmap__svg" role="img" aria-label="Mapa de Puerto Rico: cobertura en los 78 municipios" preserveAspectRatio="xMidYMid meet">
        <defs>
          <filter id="glowamb" x="-40%" y="-40%" width="180%" height="180%">
            <feGaussianBlur stdDeviation="2.4" result="b" />
            <feMerge><feMergeNode in="b" /><feMergeNode in="SourceGraphic" /></feMerge>
          </filter>
        </defs>
        <g>
          {MUNICIPIOS.map((m) => (
            <path
              d={m.d}
              class:list={['prmap__muni', { 'is-covered': COVERED_MUNIS.has(m.name) }]}
              data-name={m.name}
              tabindex="0"
              aria-label={COVERED_MUNIS.has(m.name) ? `${m.name}: obra entregada` : m.name}
            >
              <title>{m.name}</title>
            </path>
          ))}
        </g>
      </svg>
    </div>
    <figcaption class="prmap__legend small muted">
      <span><i class="sw"></i> Cobertura</span>
      <span><i class="sw sw--amb"></i> Obra entregada</span>
      <span class="prmap__count"><b>78/78</b> municipios</span>
    </figcaption>
  </figure>
</div>

<style>
  .prmap__search { padding: clamp(18px, 2.5vw, 26px); max-width: 760px; }
  .prmap__search label { display: block; margin-bottom: 10px; font-weight: 700; }
  .prmap__row { display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: 12px; }
  @media (max-width: 620px) { .prmap__row { grid-template-columns: 1fr; } }
  .prmap__row input {
    background: rgba(5, 10, 22, 0.65);
    border: 1px solid var(--line-2);
    border-radius: var(--r-sm);
    color: var(--ink);
    padding: 0.85em 1em;
    font-size: 1rem;
    min-height: 54px;
  }
  .prmap__row input:focus { outline: none; border-color: var(--ambar); box-shadow: 0 0 0 3px rgba(255, 176, 58, 0.18); }
  .prmap__readout { margin: 12px 0 0; color: var(--ink-70); }
  .prmap__readout.is-hit { color: var(--ambar); font-weight: 700; }

  .prmap__fig { margin: clamp(26px, 4vw, 40px) 0 0; }
  .prmap__scroll { overflow-x: auto; scrollbar-width: none; }
  .prmap__scroll::-webkit-scrollbar { display: none; }
  .prmap__svg { width: 100%; min-width: 660px; height: auto; overflow: visible; }

  .prmap__muni {
    fill: rgba(47, 107, 255, 0.1);
    stroke: rgba(148, 170, 210, 0.4);
    stroke-width: 0.7;
    transition: fill 0.18s ease-out;
    outline: none;
  }
  .prmap__muni.is-covered { fill: var(--ambar-2); stroke: rgba(255, 200, 120, 0.8); filter: url(#glowamb); }
  .prmap__muni:hover, .prmap__muni:focus-visible { fill: var(--cyan); cursor: pointer; }
  .prmap__muni.is-picked { fill: var(--ambar); filter: url(#glowamb); }

  .prmap__legend { display: flex; align-items: center; gap: 14px 28px; flex-wrap: wrap; margin-top: 18px; }
  .prmap__legend span { display: inline-flex; align-items: center; gap: 8px; }
  .sw { width: 12px; height: 12px; border-radius: 4px; background: rgba(47, 107, 255, 0.25); border: 1px solid var(--line-2); display: inline-block; }
  .sw--amb { background: var(--ambar-2); border-color: var(--ambar); box-shadow: 0 0 10px rgba(255, 150, 20, 0.6); }
  .prmap__count { margin-left: auto; }
  .prmap__count b { font-family: var(--f-display); font-size: 1.5rem; color: var(--ambar); margin-right: 4px; }
</style>

<script>
  const root = document.querySelector<HTMLElement>('[data-prmap]');
  if (root) {
    const input = root.querySelector<HTMLInputElement>('[data-muni-input]');
    const cta = root.querySelector<HTMLAnchorElement>('[data-muni-cta]');
    const readout = root.querySelector<HTMLElement>('[data-muni-readout]');
    const munis = Array.from(root.querySelectorAll<SVGPathElement>('.prmap__muni'));
    const byName = new Map(munis.map((m) => [m.dataset.name!.toLowerCase(), m]));
    const base = readout?.textContent ?? '';

    const pick = (raw: string) => {
      const name = raw.trim().toLowerCase();
      munis.forEach((m) => m.classList.remove('is-picked'));
      const hit = byName.get(name);
      if (!hit || !readout || !cta) {
        if (readout) { readout.textContent = base; readout.classList.remove('is-hit'); }
        return;
      }
      hit.classList.add('is-picked');
      const proper = hit.dataset.name!;
      readout.textContent = `✓ Sí, cubrimos ${proper}. Escríbanos y coordinamos la visita.`;
      readout.classList.add('is-hit');
      const msg = `Hola, estoy en ${proper} y necesito servicio de diésel para mi generador.`;
      cta.href = cta.href.split('?')[0] + '?text=' + encodeURIComponent(msg);
      hit.scrollIntoView({ block: 'nearest', inline: 'center', behavior: 'smooth' });
    };

    input?.addEventListener('change', () => pick(input.value));
    input?.addEventListener('input', () => { if (byName.has(input.value.trim().toLowerCase())) pick(input.value); });
    munis.forEach((m) => m.addEventListener('click', () => { if (input) input.value = m.dataset.name!; pick(m.dataset.name!); }));
  }
</script>
