---
import { nav, site, phoneDisplay } from '../lib/site';
const year = new Date().getFullYear();
---
<footer class="ftr">
  <div class="sheet">
    <div class="ftr__grid">
      <div>
        <div class="ftr__brand">
          <svg width="26" height="30" viewBox="0 0 40 46" fill="none" aria-hidden="true">
            <path d="M20 2.5C27.5 14 33 22.2 33 29.5A13 13 0 0 1 7 29.5C7 22.2 12.5 14 20 2.5Z" stroke="#59c2ff" stroke-width="2.4" stroke-linejoin="round"/>
            <path d="M21.8 16.4 13.6 28.2h5.1l-1.4 7.6 9.1-12.2h-5.2l1.6-7.2z" fill="var(--ambar)"/>
          </svg>
          <b>BCD Diesel</b>
        </div>
        <p class="muted small ftr__desc">
          Gestión integral de combustible diésel: limpieza de tanques, pulido de combustible
          y mantenimiento de sistemas de respaldo en los 78 municipios de Puerto Rico.
        </p>
      </div>
      <nav class="ftr__col" aria-label="Páginas">
        <h4>Navegación</h4>
        {nav.map((n) => <a href={n.href}>{n.label}</a>)}
      </nav>
      <div class="ftr__col">
        <h4>Contacto directo</h4>
        <a href={`tel:${site.phone}`} data-track="call" data-src="footer">{phoneDisplay(site.phone)}</a>
        <p class="small muted ftr__social">Instagram · Facebook · TikTok</p>
      </div>
    </div>
    <div class="ftr__base small muted">
      <span>© {year} {site.name} · Puerto Rico</span>
      <span>Servicio 24/7 · Emergencias y mantenimiento programado</span>
    </div>
  </div>
</footer>

<style>
  .ftr { border-top: 1px solid var(--line); margin-top: clamp(40px, 6vw, 80px); padding-bottom: 90px; }
  @media (min-width: 961px) { .ftr { padding-bottom: 0; } }
  .ftr__grid {
    display: grid;
    grid-template-columns: 1.3fr 0.7fr 1fr;
    gap: clamp(28px, 5vw, 72px);
    padding-block: clamp(36px, 5vw, 60px);
  }
  @media (max-width: 820px) { .ftr__grid { grid-template-columns: 1fr; gap: 30px; } }
  .ftr__brand { display: flex; align-items: center; gap: 10px; font-family: var(--f-display); font-weight: 700; letter-spacing: -0.01em; }
  .ftr__desc { margin-top: 14px; max-width: 40ch; }
  .ftr__col h4 { font-size: 0.78rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-45); margin-bottom: 14px; }
  .ftr__col a { display: block; padding: 6px 0; color: var(--ink-70); text-decoration: none; font-weight: 600; }
  .ftr__col a:hover { color: var(--ambar); }
  .ftr__social { margin: 10px 0 0; }
  .ftr__base {
    display: flex; justify-content: space-between; gap: 10px 24px; flex-wrap: wrap;
    padding-block: 20px; border-top: 1px solid var(--line);
  }
</style>
