---
const { items = ['Limpieza de tanques diesel', 'Pulido de combustible', 'Mantenimiento de generadores', 'Respuesta de emergencia', 'Cobertura en todo Puerto Rico'] } = Astro.props;
const loop = [...items, ...items];
---
<div class="ticker" aria-hidden="true">
  <div class="ticker__track">
    {loop.map((t) => (
      <span class="ticker__item">{t}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2c-3 4.5-5 7.6-5 10.2A5 5 0 0 0 17 12.2C17 9.6 15 6.5 12 2z"/></svg></span>
    ))}
  </div>
</div>

<style>
  .ticker { overflow: hidden; border-block: 1px solid var(--line); background: var(--navy-deep); }
  .ticker__track { display: inline-flex; align-items: center; white-space: nowrap; animation: ticker 38s linear infinite; }
  .ticker__item { display: inline-flex; align-items: center; gap: 28px; padding: 16px 28px; font-family: var(--f-display); text-transform: uppercase; font-size: clamp(0.95rem, 0.8rem + 0.7vw, 1.4rem); letter-spacing: 0.03em; color: var(--bone); }
  .ticker__item svg { width: 14px; height: 14px; color: var(--gold); }
  @keyframes ticker { to { transform: translateX(-50%); } }
  @media (prefers-reduced-motion: reduce) { .ticker__track { animation: none; } }
</style>
