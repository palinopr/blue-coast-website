---
// Brand mark: a diesel fuel droplet with a lightning bolt cut through it -
// "the fuel that keeps your power on". Gold on transparent; scales by `size`.
interface Props { size?: number; wordmark?: boolean; }
const { size = 38, wordmark = true } = Astro.props;
const h = Math.round(size * 1.16);
---
<span class="brand">
  <svg class="brand__mark" width={size} height={h} viewBox="0 0 40 46" fill="none" aria-hidden="true">
    <path
      d="M20 2.5C27.5 14 33 22.2 33 29.5A13 13 0 0 1 7 29.5C7 22.2 12.5 14 20 2.5Z"
      stroke="var(--gold)" stroke-width="2.3" stroke-linejoin="round"
    />
    <path
      d="M21.8 16.4 13.6 28.2h5.1l-1.4 7.6 9.1-12.2h-5.2l1.6-7.2z"
      fill="var(--gold)"
    />
  </svg>
  {wordmark && (
    <span class="brand__txt">
      <b>BLUE COAST</b>
      <i>Developers</i>
    </span>
  )}
</span>

<style>
  .brand { display: inline-flex; align-items: center; gap: 11px; }
  .brand__mark { flex: none; display: block; }
  .brand__txt { display: flex; flex-direction: column; line-height: 1; }
  .brand__txt b { font-family: var(--f-display); font-size: 1.04rem; letter-spacing: 0.05em; color: var(--bone); }
  .brand__txt i {
    font-family: var(--f-body); font-style: normal; font-weight: 600;
    font-size: 0.58rem; letter-spacing: 0.32em; text-transform: uppercase;
    color: var(--gold); margin-top: 4px;
  }
</style>
