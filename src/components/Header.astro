---
import { nav, site, waLink, waMsg, phoneDisplay } from '../lib/site';
const path = Astro.url.pathname;
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
---
<header class="hdr">
  <div class="sheet hdr__in">
    <a href="/" class="hdr__brand" aria-label="BCD Diesel — inicio">
      <svg width="30" height="35" viewBox="0 0 40 46" fill="none" aria-hidden="true">
        <path d="M20 2.5C27.5 14 33 22.2 33 29.5A13 13 0 0 1 7 29.5C7 22.2 12.5 14 20 2.5Z" stroke="url(#gb)" stroke-width="2.4" stroke-linejoin="round"/>
        <path d="M21.8 16.4 13.6 28.2h5.1l-1.4 7.6 9.1-12.2h-5.2l1.6-7.2z" fill="var(--ambar)"/>
        <defs><linearGradient id="gb" x1="0" y1="0" x2="40" y2="46"><stop stop-color="#59c2ff"/><stop offset="1" stop-color="#2f6bff"/></linearGradient></defs>
      </svg>
      <span class="hdr__name">BCD&nbsp;Diesel<small>Puerto Rico</small></span>
    </a>

    <nav class="hdr__nav" aria-label="Principal">
      {nav.map((n) => (
        <a href={n.href} class:list={['hdr__link', { 'is-active': isActive(n.href) }]}>{n.label}</a>
      ))}
    </nav>

    <div class="hdr__cta">
      <a href={`tel:${site.phone}`} class="hdr__tel" data-track="call" data-src="header">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        {phoneDisplay(site.phone)}
      </a>
      <a href={waLink(waMsg.general)} target="_blank" rel="noopener" class="btn btn-wa hdr__wa" data-track="whatsapp" data-src="header">WhatsApp</a>
      <button class="hdr__burger" popovertarget="menu" aria-label="Abrir menú">
        <span></span><span></span>
      </button>
    </div>
  </div>
</header>

<nav id="menu" popover class="menu" aria-label="Menú">
  <div class="menu__head">
    <b>Menú</b>
    <button class="menu__close" popovertarget="menu" popovertargetaction="hide" aria-label="Cerrar">✕</button>
  </div>
  {nav.map((n) => (
    <a href={n.href} class:list={['menu__link', { 'is-active': isActive(n.href) }]}>{n.label}</a>
  ))}
  <div class="menu__cta">
    <a href={waLink(waMsg.general)} target="_blank" rel="noopener" class="btn btn-wa" data-track="whatsapp" data-src="menu">Escríbanos por WhatsApp</a>
    <a href={`tel:${site.phone}`} class="btn btn-glass" data-track="call" data-src="menu">Llamar · {phoneDisplay(site.phone)}</a>
  </div>
</nav>

<style>
  .hdr {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(5, 10, 22, 0.88);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--line);
  }
  .hdr__in {
    height: var(--header-h);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
  }
  .hdr__brand { display: inline-flex; align-items: center; gap: 11px; text-decoration: none; }
  .hdr__name {
    font-family: var(--f-display);
    font-weight: 700;
    font-size: 1.06rem;
    letter-spacing: -0.02em;
    line-height: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .hdr__name small { font-family: var(--f-ui); font-weight: 700; font-size: 0.62rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--ambar); }

  .hdr__nav { display: flex; gap: 6px; }
  .hdr__link {
    padding: 9px 14px;
    border-radius: 10px;
    font-weight: 700;
    font-size: 0.94rem;
    color: var(--ink-70);
    text-decoration: none;
    transition: color 0.15s, background 0.15s;
  }
  .hdr__link:hover { color: var(--ink); background: rgba(148, 170, 210, 0.09); }
  .hdr__link.is-active { color: var(--ink); background: rgba(47, 107, 255, 0.16); }

  .hdr__cta { display: flex; align-items: center; gap: 14px; }
  .hdr__tel { display: inline-flex; align-items: center; gap: 8px; font-weight: 800; font-size: 0.95rem; color: var(--ink); text-decoration: none; }
  .hdr__tel svg { width: 16px; height: 16px; color: var(--ambar); }
  .hdr__tel:hover { color: var(--ambar); }
  .hdr__wa { min-height: 44px; padding: 0.55em 1.2em; font-size: 0.92rem; border-radius: 12px; }

  .hdr__burger {
    display: none;
    width: 44px; height: 44px;
    border: 1px solid var(--line-2);
    border-radius: 12px;
    background: rgba(148, 170, 210, 0.07);
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }
  .hdr__burger span { width: 18px; height: 2px; border-radius: 2px; background: var(--ink); }

  @media (max-width: 960px) {
    .hdr__nav, .hdr__tel, .hdr__wa { display: none; }
    .hdr__burger { display: flex; }
  }

  /* menú móvil — oculto por defecto para navegadores sin Popover API */
  .menu { display: none; }
  .menu:popover-open { display: block; }
  @supports not selector(:popover-open) {
    .menu { display: none !important; }
    .hdr__burger { display: none !important; }
    .hdr__nav { display: flex !important; }
  }
  .menu {
    inset: auto 0 0 0;
    width: 100%;
    border: 0;
    border-top: 1px solid var(--line-2);
    border-radius: 22px 22px 0 0;
    background: rgba(10, 18, 38, 0.92);
    backdrop-filter: blur(22px);
    -webkit-backdrop-filter: blur(22px);
    color: var(--ink);
    padding: 20px var(--gutter) max(24px, env(safe-area-inset-bottom));
  }
  .menu::backdrop { background: rgba(2, 5, 12, 0.6); }
  .menu__head { display: flex; justify-content: space-between; align-items: center; padding-bottom: 12px; }
  .menu__head b { font-size: 0.85rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-70); }
  .menu__close { width: 40px; height: 40px; border-radius: 10px; border: 1px solid var(--line-2); background: transparent; color: var(--ink); }
  .menu__link {
    display: block;
    padding: 15px 4px;
    font-family: var(--f-display);
    font-weight: 700;
    font-size: 1.5rem;
    letter-spacing: -0.02em;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--line);
  }
  .menu__link.is-active { color: var(--ambar); }
  .menu__cta { display: grid; gap: 12px; margin-top: 20px; }

  .menu { opacity: 1; translate: 0 0; transition: opacity 0.3s var(--ease), translate 0.3s var(--ease), overlay 0.3s allow-discrete, display 0.3s allow-discrete; }
  @starting-style { .menu:popover-open { opacity: 0; translate: 0 30px; } }
  .menu:not(:popover-open) { opacity: 0; translate: 0 30px; }
</style>
