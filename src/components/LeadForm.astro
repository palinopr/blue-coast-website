---
// Captura de leads. Tres vías de resiliencia:
//  1. Sin JS: POST nativo a Netlify Forms (action=/gracias).
//  2. Con JS: fetch a Netlify Forms + función Netlify (GoHighLevel) + redirect.
//  3. Evento de conversión (GA4 + Meta Pixel).
// name="evaluacion" se mantiene para conservar el historial en Netlify.
const { id = 'lead' } = Astro.props;
---
<form
  id={id}
  class="leadform"
  name="evaluacion"
  method="POST"
  action="/gracias"
  data-netlify="true"
  netlify-honeypot="bot-field"
>
  <input type="hidden" name="form-name" value="evaluacion" />
  <p class="hp" aria-hidden="true"><label>No llenar<input name="bot-field" tabindex="-1" autocomplete="off" /></label></p>

  <div class="leadform__row">
    <div class="field">
      <label for={`${id}-nombre`}>Nombre <span class="req">*</span></label>
      <input id={`${id}-nombre`} name="nombre" type="text" required autocomplete="name" placeholder="Su nombre" />
    </div>
    <div class="field">
      <label for={`${id}-tel`}>Teléfono o WhatsApp <span class="req">*</span></label>
      <input id={`${id}-tel`} name="telefono" type="tel" required autocomplete="tel" placeholder="(787) 000-0000" />
    </div>
  </div>

  <div class="leadform__row">
    <div class="field">
      <label for={`${id}-empresa`}>Empresa o facilidad</label>
      <input id={`${id}-empresa`} name="empresa" type="text" autocomplete="organization" placeholder="Hospital, condominio, planta…" />
    </div>
    <div class="field">
      <label for={`${id}-municipio`}>Municipio</label>
      <input id={`${id}-municipio`} name="municipio" type="text" autocomplete="address-level2" placeholder="Ej. Ponce" />
    </div>
  </div>

  <div class="field">
    <label for={`${id}-msg`}>Mensaje</label>
    <textarea id={`${id}-msg`} name="mensaje" rows="3" placeholder="Cantidad de tanques, capacidad o detalles"></textarea>
  </div>

  <button type="submit" class="btn btn-ambar">Pedir mi muestra gratis</button>
  <p class="leadform__note small muted" data-status aria-live="polite">
    Respondemos en minutos. Sus datos solo se usan para coordinar su muestra.
  </p>
</form>

<style>
  .leadform { display: flex; flex-direction: column; gap: 18px; }
  .leadform__row { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
  .hp { position: absolute; left: -9999px; }
  .leadform__note { margin: 0; }
  .leadform__note.is-error { color: var(--rojo); }
  @media (max-width: 560px) { .leadform__row { grid-template-columns: 1fr; } }
</style>

<script>
  document.querySelectorAll('form.leadform').forEach((form) => {
    const f = form as HTMLFormElement;
    const note = f.querySelector('[data-status]') as HTMLElement | null;
    f.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = f.querySelector('button[type=submit]') as HTMLButtonElement;
      const data = new FormData(f);
      if ((data.get('bot-field') as string)?.length) return;
      btn.disabled = true;
      btn.textContent = 'Enviando…';
      const body = new URLSearchParams(data as any).toString();
      const payload = Object.fromEntries(data.entries());
      try {
        // El evento de conversión se dispara UNA sola vez, en /gracias.
        const res = await fetch('/', { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body });
        if (!res.ok) throw new Error(`Netlify Forms ${res.status}`);
        fetch('/.netlify/functions/lead', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) }).catch(() => {});
        window.location.href = '/gracias';
      } catch {
        btn.disabled = false;
        btn.textContent = 'Pedir mi muestra gratis';
        if (note) {
          note.classList.add('is-error');
          note.textContent = 'No se pudo enviar. Llámenos o escríbanos por WhatsApp.';
        }
      }
    });
  });
</script>
