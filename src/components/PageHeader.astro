---
import { nav } from '../lib/site';
interface Props { title: string; eyebrow: string; sub?: string; current: string; }
const { title, eyebrow, sub, current } = Astro.props;
---
<section class="ph">
  <div class="container">
    <nav class="ph__crumb" aria-label="Ruta"><a href="/">Inicio</a><span>/</span><i>{current}</i></nav>
    <p class="eyebrow">{eyebrow}</p>
    <h1 class="display ph__title">{title}</h1>
    {sub && <p class="lead ph__sub">{sub}</p>}
  </div>
</section>

<style>
  .ph { padding-block: calc(var(--header-h) + 18px) clamp(34px, 5vw, 60px); border-bottom: 1px solid var(--line); background: radial-gradient(120% 120% at 85% -10%, rgba(201,161,74,0.10), transparent 55%), var(--navy-deep); }
  .ph__crumb { display: flex; gap: 9px; align-items: center; font-family: var(--f-body); font-weight: 600; font-size: 0.72rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--bone-faint); margin-bottom: 22px; }
  .ph__crumb a:hover { color: var(--gold); }
  .ph__crumb i { font-style: normal; color: var(--bone-dim); }
  .ph__title { margin: 16px 0 0; max-width: 18ch; }
  .ph__sub { margin: 18px 0 0; max-width: 56ch; }
</style>
